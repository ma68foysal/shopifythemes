{%- style -%}
  #ServicesGrid-{{ section.id }} {
    --srv-bg: {{ section.settings.bg_color }};
    --srv-text: {{ section.settings.text_color }};
    --srv-heading-color: {{ section.settings.heading_color }};
    --srv-card-bg: {{ section.settings.card_bg_color }};
    --srv-card-border: {{ section.settings.card_border_color }};
    --srv-accent: {{ section.settings.accent_color }};
    --srv-card-radius: {{ section.settings.card_border_radius }}px;
    --srv-pt: {{ section.settings.padding_top }}px;
    --srv-pb: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #ServicesGrid-{{ section.id }} {
      --srv-pt: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --srv-pb: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div id="ServicesGrid-{{ section.id }}" class="services-grid">
  <div class="services-grid__padding">
    <div class="services-grid__inner page-width">

      {%- comment -%} Header {%- endcomment -%}
      <div class="services-grid__header">
        {%- if section.settings.subheading != blank -%}
          <span class="services-grid__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="services-grid__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- comment -%} Cards {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="services-grid__cards">
          {%- for block in section.blocks -%}
            <div class="services-grid__card" {{ block.shopify_attributes }}>
              {%- comment -%} Card top: Number + Title + Description {%- endcomment -%}
              <div class="services-grid__card-content">
                <div class="services-grid__card-number">
                  <span class="services-grid__card-slash">//</span>
                  <span>{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
                </div>
                {%- if block.settings.title != blank -%}
                  <h3 class="services-grid__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="services-grid__card-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>

              {%- comment -%} Card bottom: Image {%- endcomment -%}
              <div class="services-grid__card-media">
                {%- if block.settings.video != blank -%}
                  {{
                    block.settings.video
                    | video_tag:
                      image_size: '800x',
                      autoplay: true,
                      loop: true,
                      muted: true,
                      controls: false,
                      class: 'services-grid__card-video'
                  }}
                {%- elsif block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                        loading: 'lazy',
                        widths: '300, 500, 600, 800',
                        sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                        alt: block.settings.image.alt | default: block.settings.title
                  }}
                {%- else -%}
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .services-grid {
    background-color: var(--srv-bg, #0a0a0a);
    color: var(--srv-text, #ffffff);
  }

  .services-grid__padding {
    padding-top: var(--srv-pt, 80px);
    padding-bottom: var(--srv-pb, 80px);
  }

  .services-grid__inner {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;
  }

  /* Header */
  .services-grid__header {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 2.4rem;
  }

  .services-grid__subheading {
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.65;
    color:{{section.settings.header_subheading_color}};
  }

  .services-grid__heading {
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    color: {{section.settings.header_heading_color}};
    letter-spacing: -0.02em;
  }

  /* Cards — mobile horizontal slider */
  .services-grid__cards {
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.4rem;
  }

  .services-grid__cards::-webkit-scrollbar {
    display: none;
  }

  /* Card */
  .services-grid__card {
    background-color: var(--srv-card-bg, #141414);
    border: 1px solid var(--srv-card-border, #222222);
    border-radius: var(--srv-card-radius, 12px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 0 0 82%;
    max-width: 82%;
    scroll-snap-align: start;
  }

  .services-grid__card-content {
    padding: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    flex-grow: 1;
  }

  .services-grid__card-number {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.4rem;
    font-weight: 300;
    {% comment %} opacity: 0.5; {% endcomment %}
  }

  .services-grid__card-slash {
    color: var(--srv-accent, #ff4500);
    font-weight: 800;
  }

  .services-grid__card-title {
    font-size: 2rem;
    font-weight: 500;
    line-height: 26px;
    margin: 0;
    color: var(--srv-heading-color, #ffffff);
  }

  .services-grid__card-desc {
    font-size: 1.4rem;
    line-height: 2rem;
    margin: 0;
    {% comment %} opacity: 0.5; {% endcomment %}
  }

  .services-grid__card-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }

  .services-grid__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .services-grid__card:hover .services-grid__card-media img,
  .services-grid__card:hover .services-grid__card-media video {
    transform: scale(1.04);
  }

  .services-grid__card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .services-grid__card-media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (min-width: 750px) {
    .services-grid__heading {
      font-size: 3.6rem;
    }

    .services-grid__cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      overflow: visible;
    }

    .services-grid__card {
      flex: none;
      max-width: none;
    }

    .services-grid__card-content {
      padding: 2.8rem;
    }

    .services-grid__card-title {
      font-size: 2.2rem;
    }
  }

  @media screen and (min-width: 990px) {
    .services-grid__heading {
      font-size: 4.8rem;
    }

    .services-grid__cards {
      grid-template-columns: repeat(3, 1fr);
    }


    .services-grid__card-content {
      padding: 3.2rem;
      gap: 1.4rem;
    }
    .services-grid__card-number{
      font-size: 3.6rem;
    }

    .services-grid__card-title {
      font-size: 2.4rem;
    }

    .services-grid__card-desc {
      font-size: 1.35rem;
    }
  }
</style>

