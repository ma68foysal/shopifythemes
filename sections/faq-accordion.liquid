{%- style -%}
  #FaqAccordion-{{ section.id }} {
    --faq-bg: {{ section.settings.bg_color }};
    --faq-text: {{ section.settings.text_color }};
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-accent: {{ section.settings.accent_color }};
    --faq-divider: {{ section.settings.divider_color }};
    --faq-pt: {{ section.settings.padding_top }}px;
    --faq-pb: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #FaqAccordion-{{ section.id }} {
      --faq-pt: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --faq-pb: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div id="FaqAccordion-{{ section.id }}" class="faq-accordion">
  <div class="faq-accordion__padding">
    <div class="faq-accordion__inner page-width">

      {%- comment -%} Header {%- endcomment -%}
      <div class="faq-accordion__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq-accordion__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="faq-accordion__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} FAQ Groups & Items {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="faq-accordion__content">
          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'category' -%}
                <div class="faq-accordion__category" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h3 class="faq-accordion__category-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <p class="faq-accordion__category-subtitle">{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                </div>

              {%- when 'question' -%}
                <details class="faq-accordion__item" {{ block.shopify_attributes }}>
                  <summary class="faq-accordion__question">
                    <span class="faq-accordion__question-text">{{ block.settings.question }}</span>
                    <span class="faq-accordion__icon" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line class="faq-accordion__icon-h" x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                      </svg>
                    </span>
                  </summary>
                  <div class="faq-accordion__answer">
                    <div class="faq-accordion__answer-inner">
                      {{ block.settings.answer }}
                    </div>
                  </div>
                </details>

            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .faq-accordion {
    background-color: var(--faq-bg, #0a0a0a);
    color: var(--faq-text, #ffffff);
  }

  .faq-accordion__padding {
    padding-top: var(--faq-pt, 80px);
    padding-bottom: var(--faq-pb, 80px);
  }

  .faq-accordion__inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* Header */
  .faq-accordion__header {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    border-bottom: 1px solid var(--faq-divider, #222222);
    padding-bottom: 3.2rem;
  }

  .faq-accordion__heading {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
    color: var(--faq-heading-color, #ffffff);
    letter-spacing: -0.02em;
  }

  .faq-accordion__description {
    font-size: 1.6rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.65;
    max-width: 64rem;
  }

  /* Content */
  .faq-accordion__content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Category header */
  .faq-accordion__category {
    padding: 3.2rem 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .faq-accordion__category:first-child {
    padding-top: 0;
  }

  .faq-accordion__category-title {
    font-size: 2.6rem;
    font-weight: 800;
    margin: 0;
    color: var(--faq-heading-color, #ffffff);
  }

  .faq-accordion__category-subtitle {
    font-size: 1.5rem;
    margin: 0;
    opacity: 0.6;
  }

  /* Accordion item */
  .faq-accordion__item {
    border-bottom: 1px solid var(--faq-divider, #222222);
  }

  .faq-accordion__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 0;
    cursor: pointer;
    list-style: none;
    -webkit-appearance: none;
  }

  .faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__question::marker {
    display: none;
    content: '';
  }

  .faq-accordion__question-text {
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--faq-heading-color, #ffffff);
  }

  .faq-accordion__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background-color: var(--faq-accent, #ff4500);
    color: #ffffff;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-accordion__icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  /* Rotate icon on open */
  .faq-accordion__item[open] .faq-accordion__icon {
    background-color: rgba(255, 255, 255, 0.15);
  }

  .faq-accordion__icon-h {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .faq-accordion__item[open] .faq-accordion__icon-h {
    transform: scaleY(0);
    opacity: 0;
  }

  /* Answer */
  .faq-accordion__answer {
    overflow: hidden;
  }

  .faq-accordion__answer-inner {
    padding: 0 0 2.4rem;
    font-size: 1.6rem;
    line-height: 1.7;
    opacity: 0.7;
    max-width: 72rem;
  }

  .faq-accordion__answer-inner p {
    margin: 0 0 1rem;
  }

  .faq-accordion__answer-inner p:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    .faq-accordion__heading {
      font-size: 4.2rem;
    }

    .faq-accordion__question-text {
      font-size: 1.8rem;
    }

    .faq-accordion__category-title {
      font-size: 2.8rem;
    }

    .faq-accordion__category-subtitle {
      font-size: 1.6rem;
    }
  }

  @media screen and (min-width: 990px) {
    .faq-accordion__heading {
      font-size: 5rem;
    }

    .faq-accordion__question-text {
      font-size: 2rem;
    }

    .faq-accordion__category-title {
      font-size: 3.2rem;
    }

    .faq-accordion__category-subtitle {
      font-size: 1.8rem;
      opacity: 0.6;
    }

    .faq-accordion__answer-inner {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var faqSection = document.getElementById('FaqAccordion-{{ section.id }}');
    if (!faqSection) return;

    /* Optional: close other items when one opens */
    {%- if section.settings.single_open -%}
    faqSection.querySelectorAll('.faq-accordion__item').forEach(function (item) {
      item.addEventListener('toggle', function () {
        if (item.open) {
          faqSection.querySelectorAll('.faq-accordion__item').forEach(function (other) {
            if (other !== item && other.open) {
              other.removeAttribute('open');
            }
          });
        }
      });
    });
    {%- endif -%}
  });
</script>

