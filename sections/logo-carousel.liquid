{{ 'section-logo-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #LogoCarousel-{{ section.id }} {
    --logo-carousel-bg: {{ section.settings.bg_color }};
    --logo-carousel-border: {{ section.settings.border_color }};
    --logo-carousel-speed: {{ section.settings.speed }}s;
    --logo-carousel-gap: {{ section.settings.gap }}px;
    --logo-carousel-gap-mobile: {{ section.settings.gap_mobile }}px;
    --logo-carousel-height: {{ section.settings.logo_height }}px;
    --logo-carousel-height-mobile: {{ section.settings.logo_height_mobile }}px;
    --logo-carousel-opacity: {{ section.settings.logo_opacity | divided_by: 100.0 }};
    --logo-carousel-pause: {% if section.settings.pause_on_hover %}paused{% else %}running{% endif %};
    --logo-carousel-pt: {{ section.settings.padding_top }}px;
    --logo-carousel-pb: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{%- liquid
  assign logo_count = 0
  for block in section.blocks
    if block.settings.logo != blank
      assign logo_count = logo_count | plus: 1
    endif
  endfor
-%}

<div
  id="LogoCarousel-{{ section.id }}"
  class="logo-carousel{% if section.settings.fade_edges %} logo-carousel--fade-edges{% endif %}"
>
  <div class="logo-carousel__padding">
    {%- if section.blocks.size > 0 -%}
      <div
        class="logo-carousel__track{% if section.settings.direction == 'right' %} logo-carousel__track--reverse{% endif %}"
        aria-label="{{ section.settings.aria_label | default: 'Our trusted partners' }}"
      >
        {%- comment -%} Original set of logos {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.logo != blank -%}
            <div class="logo-carousel__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a
                  href="{{ block.settings.link }}"
                  {% if block.settings.open_new_tab %}
                    target="_blank" rel="noopener noreferrer"
                  {% endif %}
                  aria-label="{{ block.settings.logo.alt | default: 'Partner logo' }}"
                >
              {%- endif -%}

              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  widths: '100, 150, 200, 300, 400',
                  sizes: '16rem',
                  alt: block.settings.logo.alt
                | default: 'Logo'
              }}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Duplicate set for seamless infinite loop {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.logo != blank -%}
            <div class="logo-carousel__item" aria-hidden="true">
              {%- if block.settings.link != blank -%}
                <a
                  href="{{ block.settings.link }}"
                  {% if block.settings.open_new_tab %}
                    target="_blank" rel="noopener noreferrer"
                  {% endif %}
                  tabindex="-1"
                >
              {%- endif -%}

              {{
                block.settings.logo
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  widths: '100, 150, 200, 300, 400',
                  sizes: '16rem',
                  alt: block.settings.logo.alt
                | default: 'Logo'
              }}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Logo Carousel",
  "tag": "section",
  "class": "section section--logo-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color (top & bottom)",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Logo settings"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (desktop)",
      "min": 15,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo height (mobile)",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70,
      "info": "Logos reach full opacity on hover"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Lower = faster. Duration for one full cycle"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between logos (desktop)",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between logos (mobile)",
      "min": 15,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "fade_edges",
      "label": "Fade edges",
      "default": false,
      "info": "Add gradient fade on left and right edges"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Our trusted partners"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image",
          "info": "Recommended: SVG or transparent PNG. Max height will be controlled by section settings."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Carousel",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
