{{ 'section-hero-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #HeroBanner-{{ section.id }} {
    --hero-padding-top: {{ section.settings.padding_top }}px;
    --hero-padding-bottom: {{ section.settings.padding_bottom }}px;
    --hero-card-radius: {{ section.settings.card_border_radius }}px;
    --hero-btn-bg: {{ section.settings.button_color }};
    --hero-btn-text: {{ section.settings.button_text_color }};
    --hero-btn-hover-bg: {{ section.settings.button_hover_color }};
    --hero-btn-radius: {{ section.settings.button_border_radius }}px;
  }
  .color-bg{
    background-color: {{ section.settings.section_bg }};
  }

  @media screen and (max-width: 749px) {
    #HeroBanner-{{ section.id }} {
      --hero-padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --hero-padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div
  id="HeroBanner-{{ section.id }}"
  class="hero-banner color-bg gradient"
>
  <div class="hero-banner__padding">
    <div class="hero-banner__inner page-width">
      {%- comment -%} TOP: Heading + Badge {%- endcomment -%}
      <div class="hero-banner__top">
        <div class="hero-banner__heading-wrap">
          {%- if section.settings.heading != blank -%}
            <h1 class="hero-banner__heading">
              {{ section.settings.heading }}
            </h1>
          {%- endif -%}

          {%- if section.settings.subtitle != blank -%}
            <p class="hero-banner__subtitle">
              {{ section.settings.subtitle }}
            </p>
          {%- endif -%}
        </div>

        {%- if section.settings.badge_image != blank -%}
          <div class="hero-banner__badge">
            {{
              section.settings.badge_image
              | image_url: width: 200
              | image_tag:
                loading: 'lazy',
                widths: '80, 120, 160, 200',
                sizes: '8rem',
                alt: section.settings.badge_image.alt
              | default: 'Badge'
            }}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} CARDS GRID {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="hero-banner__cards">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'card' -%}
                <div
                  class="hero-banner__card"
                  style="min-height: {{ block.settings.card_min_height_mobile }}px;"
                  data-desktop-height="{{ block.settings.card_min_height_desktop }}"
                  {{ block.shopify_attributes }}
                >
                  {%- comment -%} Card Media Background {%- endcomment -%}
                  <div class="hero-banner__card-media">
                    {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                      {{
                        block.settings.video
                        | video_tag:
                          image_size: '2000x',
                          autoplay: block.settings.video_autoplay,
                          loop: block.settings.video_loop,
                          muted: true,
                          controls: false
                      }}
                    {%- elsif block.settings.media_type == 'video_url' and block.settings.video_url != blank -%}
                      {%- liquid
                        assign video_id = block.settings.video_url | split: '/' | last
                        assign video_id = video_id | split: '=' | last | split: '&' | first
                        assign video_host = 'youtube'
                        if block.settings.video_url contains 'vimeo'
                          assign video_host = 'vimeo'
                        endif
                      -%}
                      {%- if video_host == 'youtube' -%}
                        <iframe
                          src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ block.settings.video_autoplay | default: false }}&mute=1&loop=1&playlist={{ video_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          frameborder="0"
                          title="{{ block.settings.card_title | escape }}"
                        ></iframe>
                      {%- elsif video_host == 'vimeo' -%}
                        <iframe
                          src="https://player.vimeo.com/video/{{ video_id }}?autoplay={{ block.settings.video_autoplay | default: false }}&muted=1&loop=1&controls=0&background=1"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          frameborder="0"
                          title="{{ block.settings.card_title | escape }}"
                        ></iframe>
                      {%- endif -%}
                    {%- elsif block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 1920
                        | image_tag:
                          loading: 'lazy',
                          widths: '375, 550, 750, 960, 1100, 1440, 1920',
                          sizes: '(min-width: 750px) 50vw, 100vw',
                          alt: block.settings.image.alt
                        | default: block.settings.card_title
                      }}
                    {%- else -%}
                      {{ 'hero-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>

                  {%- comment -%} Card Overlay {%- endcomment -%}
                  {%- if block.settings.overlay_opacity > 0 -%}
                    {%- assign overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0 -%}
                    <div
                      class="hero-banner__card-overlay hero-banner__card-overlay--{{ block.settings.overlay_style }}"
                      style="
                        --card-overlay-color: {{ block.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
                        --card-overlay-color-end: {{ block.settings.overlay_color | color_modify: 'alpha', 0 }};
                        --card-overlay-direction: {{ block.settings.overlay_gradient_direction }};
                      "
                    >&nbsp;</div>
                  {%- endif -%}

                  {%- comment -%} Card Content {%- endcomment -%}
                  <div class="hero-banner__card-content">
                    {%- comment -%} Top: all text content {%- endcomment -%}
                    <div class="hero-banner__card-top">
                      {%- if block.settings.card_icon != blank -%}
                        <div class="hero-banner__card-icon">
                          {{
                            block.settings.card_icon
                            | image_url: width: 100
                            | image_tag:
                              loading: 'lazy',
                              widths: '48, 72, 100',
                              sizes: '3.6rem',
                              alt: block.settings.card_icon.alt | default: 'Icon'
                          }}
                          {%- if block.settings.card_tag != blank -%}
                        <span class="hero-banner__card-tag">
                          {{ block.settings.card_tag }}
                        </span>
                      {%- endif -%}
                        </div>
                      {%- endif -%}
                      
                      {%- if block.settings.card_title != blank -%}
                        <h3 class="hero-banner__card-title">
                          {{ block.settings.card_title }}
                        </h3>
                      {%- endif -%}
                      {%- if block.settings.card_description != blank -%}
                        <p class="hero-banner__card-description">
                          {{ block.settings.card_description }}
                        </p>
                      {%- endif -%}
                    </div>

                    {%- comment -%} Bottom: CTA Button {%- endcomment -%}
                    {%- if block.settings.button_label != blank -%}
                      <div class="hero-banner__card-cta">
                        <a
                          {% if block.settings.button_link != blank %}
                            href="{{ block.settings.button_link }}"
                          {% else %}
                            role="link" aria-disabled="true"
                          {% endif %}
                          class="hero-banner__card-btn hero-banner__card-btn--{{ block.settings.button_style }}"
                        >
                          {{ block.settings.button_label | escape }}
                          <span class="hero-banner__card-btn-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                              <line x1="12" y1="5" x2="12" y2="19"></line>
                              <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                          </span>
                        </a>
                      </div>
                    {%- endif -%}
                  </div>

                  {%- comment -%} Video Play Button (non-autoplay videos) {%- endcomment -%}
                  {%- if block.settings.media_type == 'video' or block.settings.media_type == 'video_url' -%}
                    {%- unless block.settings.video_autoplay -%}
                      <button
                        class="hero-banner__play-btn"
                        aria-label="{{ 'accessibility.play_video' | t }}"
                        data-hero-play
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                          <polygon points="5 3 19 12 5 21 5 3"></polygon>
                        </svg>
                      </button>
                    {%- endunless -%}
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var heroSection = document.getElementById('HeroBanner-{{ section.id }}');
    if (!heroSection) return;

    /* Handle video play buttons for non-autoplay cards */
    heroSection.querySelectorAll('[data-hero-play]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = btn.closest('.hero-banner__card');
        var video = card.querySelector('video');
        var iframe = card.querySelector('iframe');

        if (video) {
          video.play();
          card.classList.add('video-playing');
        } else if (iframe) {
          var src = iframe.getAttribute('src');
          if (src.indexOf('autoplay=0') !== -1) {
            iframe.setAttribute('src', src.replace('autoplay=0', 'autoplay=1'));
          } else if (src.indexOf('autoplay=false') !== -1) {
            iframe.setAttribute('src', src.replace('autoplay=false', 'autoplay=1'));
          }
          card.classList.add('video-playing');
        }
      });
    });

    /* Responsive min-height for cards on desktop */
    function updateCardHeights() {
      heroSection.querySelectorAll('.hero-banner__card').forEach(function (card) {
        if (window.innerWidth >= 750) {
          var desktopHeight = card.getAttribute('data-desktop-height');
          if (desktopHeight) {
            card.style.minHeight = desktopHeight + 'px';
          }
        }
      });
    }

    updateCardHeights();
    window.addEventListener('resize', updateCardHeights);
  });
</script>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "We know Shopify.Your growth partner."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle text",
      "default": "Los Angeles-based Shopify Plus design and development agency. Trusted since 2019 by high-growth eCommerce brands for strategic builds and long-term support."
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image",
      "info": "Displayed in the top-right corner. Recommended: 160x160px"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background color",
      "default": "#ff4500"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Card settings"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Service Card",
      "limit": 4,
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Shopify hosted video" },
            { "value": "video_url", "label": "Video URL (YouTube/Vimeo)" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image",
          "info": "Recommended: 960x600px or larger"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify hosted video",
          "info": "Displayed when media type is 'Shopify hosted video'"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL",
          "info": "YouTube or Vimeo URL. Displayed when media type is 'Video URL'"
        },
        {
          "type": "checkbox",
          "id": "video_autoplay",
          "label": "Autoplay video",
          "default": true,
          "info": "Videos are always muted when autoplaying"
        },
        {
          "type": "checkbox",
          "id": "video_loop",
          "label": "Loop video",
          "default": true
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 40
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "select",
          "id": "overlay_style",
          "label": "Overlay style",
          "options": [
            { "value": "solid", "label": "Solid" },
            { "value": "gradient", "label": "Gradient" }
          ],
          "default": "gradient"
        },
        {
          "type": "select",
          "id": "overlay_gradient_direction",
          "label": "Gradient direction",
          "options": [
            { "value": "to top", "label": "Bottom to top" },
            { "value": "to bottom", "label": "Top to bottom" },
            { "value": "to right", "label": "Left to right" },
            { "value": "to left", "label": "Right to left" }
          ],
          "default": "to top",
          "info": "Only applies when overlay style is 'Gradient'"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "card_icon",
          "label": "Card icon",
          "info": "Small icon above title. Recommended: 72x72px"
        },
        {
          "type": "text",
          "id": "card_tag",
          "label": "Tag / subtitle",
          "default": "SHOPIFY WEBSITE DESIGN & DEVELOPMENT"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Card title",
          "default": "Shopify Website Design & Development"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Card description",
          "default": "Whether you need a fast, strategic Shopify launch or a fully custom tailored shopping experience."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Primary (filled)" },
            { "value": "secondary", "label": "Secondary (outline)" }
          ],
          "default": "primary"
        },
        {
          "type": "header",
          "content": "Card height"
        },
        {
          "type": "range",
          "id": "card_min_height_mobile",
          "label": "Minimum height (mobile)",
          "min": 200,
          "max": 600,
          "step": 10,
          "unit": "px",
          "default": 360
        },
        {
          "type": "range",
          "id": "card_min_height_desktop",
          "label": "Minimum height (desktop)",
          "min": 300,
          "max": 700,
          "step": 10,
          "unit": "px",
          "default": 480
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "card_tag": "SHOPIFY WEBSITE DESIGN & DEVELOPMENT",
            "card_title": "Shopify Website Design & Development",
            "card_description": "Whether you need a fast, strategic Shopify launch or a fully custom tailored shopping experience.",
            "button_label": "Learn More"
          }
        },
        {
          "type": "card",
          "settings": {
            "card_tag": "FRACTIONAL SHOPIFY WEBSITE TEAMS",
            "card_title": "Fractional Shopify Website Teams",
            "card_description": "Our Los Angeles-based team provides senior strategic design and development to level up your website and drive results.",
            "button_label": "Learn More"
          }
        }
      ]
    }
  ]
}
{% endschema %}
