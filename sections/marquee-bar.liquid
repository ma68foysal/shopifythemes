{%- style -%}
  #MarqueeBar-{{ section.id }} {
    --marquee-bg: {{ section.settings.bg_color }};
    --marquee-text: {{ section.settings.text_color }};
    --marquee-speed: {{ section.settings.speed }}s;
    --marquee-dot: {{ section.settings.dot_color }};
    --marquee-pt: {{ section.settings.padding_top }}px;
    --marquee-pb: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

{%- if section.settings.text != blank -%}
<div id="MarqueeBar-{{ section.id }}" class="marquee-bar">
  <div class="marquee-bar__padding">
    <div class="marquee-bar__track{% if section.settings.direction == 'right' %} marquee-bar__track--reverse{% endif %}">
      {%- comment -%} Repeat the content enough times for seamless loop {%- endcomment -%}
      {%- for i in (1..4) -%}
        <div class="marquee-bar__content" {% if i > 1 %}aria-hidden="true"{% endif %}>
          {%- assign items = section.settings.text | split: '|' -%}
          {%- for item in items -%}
            <span class="marquee-bar__item">{{ item | strip }}</span>
            <span class="marquee-bar__dot" aria-hidden="true">●</span>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

<style>
  .marquee-bar {
    background-color: var(--marquee-bg, #ff4500);
    color: var(--marquee-text, #ffffff);
    overflow: hidden;
    position: relative;
  }

  .marquee-bar__padding {
    padding-top: var(--marquee-pt, 16px);
    padding-bottom: var(--marquee-pb, 16px);
  }

  .marquee-bar__track {
    display: flex;
    width: max-content;
    animation: marqueeBarScroll var(--marquee-speed, 40s) linear infinite;
  }

  .marquee-bar__track:hover {
    animation-play-state: paused;
  }

  .marquee-bar__track--reverse {
    animation-direction: reverse;
  }

  .marquee-bar__content {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .marquee-bar__item {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0 1.2rem;
    white-space: nowrap;
  }

  .marquee-bar__dot {
    font-size: 0.6rem;
    color: var(--marquee-dot, #ffffff);
    opacity: 0.6;
    flex-shrink: 0;
  }

  @keyframes marqueeBarScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-25%);
    }
  }

  @media screen and (min-width: 750px) {
    .marquee-bar__item {
      font-size: 1.3rem;
      padding: 0 1.6rem;
    }
  }
</style>

{% schema %}
{
  "name": "Marquee Bar",
  "tag": "section",
  "class": "section section--marquee-bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Marquee text",
      "default": "Official Shopify Plus Agency Partners|9 Figures In Revenue By Managed Merchants In 2025|Millions Of Customers Served By Our Websites & Apps Monthly",
      "info": "Separate each item with | (pipe character)"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 25,
      "info": "Lower = faster"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ff4500"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot separator color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Marquee Bar"
    }
  ]
}
{% endschema %}
