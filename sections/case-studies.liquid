{%- style -%}
  #CaseStudies-{{ section.id }} {
    --cs-bg: {{ section.settings.bg_color }};
    --cs-text: {{ section.settings.text_color }};
    --cs-heading-color: {{ section.settings.heading_color }};
    --cs-card-bg: {{ section.settings.card_bg_color }};
    --cs-card-border: {{ section.settings.card_border_color }};
    --cs-accent: {{ section.settings.accent_color }};
    --cs-btn-bg: {{ section.settings.button_bg_color }};
    --cs-btn-text: {{ section.settings.button_text_color }};
    --cs-btn-hover-bg: {{ section.settings.button_hover_color }};
    --cs-card-radius: {{ section.settings.card_border_radius }}px;
    --cs-pt: {{ section.settings.padding_top }}px;
    --cs-pb: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #CaseStudies-{{ section.id }} {
      --cs-pt: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --cs-pb: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div id="CaseStudies-{{ section.id }}" class="case-studies">
  <div class="case-studies__padding">
    <div class="case-studies__inner page-width">
      {%- comment -%} Header {%- endcomment -%}
      <div class="case-studies__header">
        <div class="case-studies__header-left">
          {%- if section.settings.subheading != blank -%}
            <span class="case-studies__subheading">{{ section.settings.subheading }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="case-studies__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
            class="case-studies__header-btn"
          >
            <span>{{ section.settings.button_label | escape }}</span>
            <span class="case-studies__header-btn-icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Grid — cards wrapped in pairs for mobile dual slider {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="case-studies__grid">
          {%- for block in section.blocks -%}
            {%- assign pair_index = forloop.index | modulo: 2 -%}
            {%- if pair_index == 1 -%}
              <div class="case-studies__pair">
            {%- endif -%}

            <div class="case-studies__card" {{ block.shopify_attributes }}>
              <div class="case-studies__card-label">
                <span class="case-studies__card-slash">//</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="case-studies__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
              </div>
              <div class="case-studies__card-media">
                {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
                {%- if block.settings.video != blank -%}
                  {{
                    block.settings.video
                    | video_tag:
                      image_size: '960x',
                      autoplay: true,
                      loop: true,
                      muted: true,
                      controls: false,
                      class: 'case-studies__card-video'
                  }}
                {%- elsif block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 960
                    | image_tag:
                      loading: 'lazy',
                      widths: '375, 550, 750, 960',
                      sizes: '(min-width: 750px) 45vw, 90vw',
                      alt: block.settings.image.alt | default: block.settings.title
                  }}
                {%- else -%}
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if block.settings.link != blank -%}</a>{%- endif -%}
              </div>
            </div>

            {%- if pair_index == 0 or forloop.last -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Mobile bottom button {%- endcomment -%}
      {%- if section.settings.button_label != blank -%}
        <div class="case-studies__bottom-btn">
          <a
            {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
            class="case-studies__header-btn"
          >
            <span>{{ section.settings.button_label | escape }}</span>
            <span class="case-studies__header-btn-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .case-studies {
    background-color: var(--cs-bg, #0a0a0a);
    color: var(--cs-text, #ffffff);
  }

  .case-studies__padding {
    padding-top: var(--cs-pt, 80px);
    padding-bottom: var(--cs-pb, 80px);
  }

  .case-studies__inner {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;
  }

  /* Header */
  .case-studies__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .case-studies__header-left {
    display: flex;
    flex-direction: column;
    gap: 4.8rem;
  }

  .case-studies__subheading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.45;
  }

  .case-studies__heading {
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    color: var(--cs-heading-color, #ffffff);
    letter-spacing: -0.02em;
  }

  /* Header button */
  .case-studies__header-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.6rem 0.6rem 2rem;
    border-radius: 100px;
    background-color: var(--cs-btn-bg, #ff4500);
    color: var(--cs-btn-text, #ffffff);
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
    position: relative;
    overflow: hidden;
    z-index: 0;
    transition: color 0.4s ease;
    flex-shrink: 0;
  }

  .case-studies__header-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: var(--cs-btn-hover-bg, #ffffff);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    border-radius: inherit;
  }

  .case-studies__header-btn:hover::before {
    transform: translateY(0);
  }

  .case-studies__header-btn:hover {
    color: var(--cs-btn-hover-bg, #000000);
  }

  .case-studies__header-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    {% comment %} background-color: rgba(255, 255, 255, 0.2); {% endcomment %}
    flex-shrink: 0;
  }

  .case-studies__header-btn-icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  /* Mobile: hide header btn, show bottom btn */
  .case-studies__header .case-studies__header-btn {
    display: none;
  }

  .case-studies__bottom-btn {
    display: flex;
    justify-content: center;
  }

  /* Mobile: horizontal slider of vertically-paired cards */
  .case-studies__grid {
    display: flex;
    gap: 1.2rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .case-studies__grid::-webkit-scrollbar {
    display: none;
  }

  /* Pair wrapper — each slide = 1 column with 2 cards stacked */
  .case-studies__pair {
    flex: 0 0 80%;
    max-width: 80%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }

  /* Card */
  .case-studies__card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0;
  }

  .case-studies__card-label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .case-studies__card-slash {
    color: var(--cs-accent, #ff4500);
    font-weight: 800;
    font-size: 1.6rem;
  }

  .case-studies__card-title {
    font-size: 2rem;
    font-weight: 300;
    margin: 0;
    color: var(--cs-heading-color, #ffffff);
  }

  .case-studies__card-media {
    border-radius: var(--cs-card-radius, 8px);
    overflow: hidden;
    background-color: var(--cs-card-bg, #141414);
    border: 1px solid var(--cs-card-border, #222222);
    aspect-ratio: 16 / 10;
    position: relative;
  }

  .case-studies__card-media a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .case-studies__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .case-studies__card-media:hover img,
  .case-studies__card-media:hover video {
    transform: scale(1.03);
  }

  .case-studies__card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .case-studies__card-media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (min-width: 750px) {
    .case-studies__header .case-studies__header-btn {
      display: inline-flex;
    }

    .case-studies__bottom-btn {
      display: none;
    }

    .case-studies__heading {
      font-size: 3.6rem;
    }

    .case-studies__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      overflow: visible;
    }

    /* Flatten pairs on desktop — pairs become transparent wrappers */
    .case-studies__pair {
      display: contents;
    }

    .case-studies__card-title {
      font-size: 4rem;
    }
  }

  @media screen and (min-width: 990px) {
    .case-studies__heading {
      font-size: 4.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Case Studies",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "100+ COMPLETED PROJECTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our case studies"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ff4500"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#ff4500"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Project name",
          "default": "Project Name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Project screenshot",
          "info": "Recommended: 960x600px"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Project video",
          "info": "Upload a video. If provided, video takes priority over image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Project link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Case Studies",
      "blocks": [
        { "type": "case_study", "settings": { "title": "Zia Tile" } },
        { "type": "case_study", "settings": { "title": "Cousins Maine Lobster" } },
        { "type": "case_study", "settings": { "title": "Nature's Answer" } },
        { "type": "case_study", "settings": { "title": "Kinto" } },
        { "type": "case_study", "settings": { "title": "Portola Paints" } },
        { "type": "case_study", "settings": { "title": "Level" } }
      ]
    }
  ]
}
{% endschema %}
