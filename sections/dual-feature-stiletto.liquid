<style>
  .dual-stiletto {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_side }}px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .dual-stiletto__grid {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.grid_gap }}px;
  }

  /* Card shared */
  .dual-stiletto__card {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ section.settings.card_ratio }};
  }

  .dual-stiletto__card img,
  .dual-stiletto__card svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Slideshow images */
  .dual-stiletto__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
    z-index: 0;
  }

  .dual-stiletto__slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  .dual-stiletto__slide img,
  .dual-stiletto__slide svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Overlay */
  .dual-stiletto__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  /* Overlay gradient applied via inline style per card */

  /* Content */
  .dual-stiletto__content {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    padding: {{ section.settings.content_padding }}px;
    color: {{ section.settings.text_color }};
  }

  /* Content positions: vertical */
  .dual-stiletto__content--top-left,
  .dual-stiletto__content--top-center,
  .dual-stiletto__content--top-right { flex-direction: column; justify-content: flex-start; }

  .dual-stiletto__content--middle-left,
  .dual-stiletto__content--middle-center,
  .dual-stiletto__content--middle-right { flex-direction: column; justify-content: center; }

  .dual-stiletto__content--bottom-left,
  .dual-stiletto__content--bottom-center,
  .dual-stiletto__content--bottom-right { flex-direction: column; justify-content: flex-end; }

  /* Content positions: horizontal */
  .dual-stiletto__content--top-left,
  .dual-stiletto__content--middle-left,
  .dual-stiletto__content--bottom-left { align-items: flex-start; text-align: left; }

  .dual-stiletto__content--top-center,
  .dual-stiletto__content--middle-center,
  .dual-stiletto__content--bottom-center { align-items: center; text-align: center; }

  .dual-stiletto__content--top-right,
  .dual-stiletto__content--middle-right,
  .dual-stiletto__content--bottom-right { align-items: flex-end; text-align: right; }

  .dual-stiletto__text-box {
    max-width: 360px;
  }

  .dual-stiletto__heading {
    font-size: clamp(22px, {{ section.settings.heading_size }}px, 48px);
    font-weight: 400;
    font-style: normal;
    line-height: 1.15;
    margin: 0 0 8px;
    {% comment %} font-family: var(--font-heading-family); {% endcomment %}
    color: {{ section.settings.text_color }};
  }

  .dual-stiletto__description {
    font-size: {{ section.settings.desc_size }}px;
    margin: 0 0 18px;
    opacity: 0.8;
    line-height: 1.5;
  }

  .dual-stiletto__btn {
    display: inline-block;
    text-decoration: none;
    font-size: {{ section.settings.btn_size }}px;
    letter-spacing: 0.06em;
    padding: 10px 24px;
    border: 1px solid {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    background: {{ section.settings.btn_bg }};
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s ease, border-color 0.3s ease;
  }

  .dual-stiletto__btn span {
    position: relative;
    z-index: 2;
  }

  .dual-stiletto__btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -10%;
    width: 0;
    height: 100%;
    background: {{ section.settings.btn_hover_bg }};
    z-index: -1;
    transform: skewX(12deg);
    transition: width 0.45s ease;
  }

  .dual-stiletto__btn:hover {
    color: {{ section.settings.btn_hover_text }};
    border-color: {{ section.settings.btn_hover_bg }};
  }

  .dual-stiletto__btn:hover::before {
    width: 130%;
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    .dual-stiletto__grid {
      grid-template-columns: 1fr;
    }

    .dual-stiletto__card {
      aspect-ratio: 3 / 4;
    }
  }
</style>

<section class="dual-stiletto">
  <div class="dual-stiletto__grid">

    {%- comment -%} ---- LEFT: Static image ---- {%- endcomment -%}
    <div class="dual-stiletto__card dual-stiletto__card--left">
      {%- if section.settings.left_image != blank -%}
        {{ section.settings.left_image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 100vw, 50vw', widths: '375, 550, 750, 1000' }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      <div class="dual-stiletto__overlay" style="background: linear-gradient(to top, {{ section.settings.left_overlay_color | default: '#000000' | color_modify: 'alpha', section.settings.left_overlay_opacity | divided_by: 100.0 }} 0%, transparent 60%);">&nbsp;</div>
      <div class="dual-stiletto__content dual-stiletto__content--{{ section.settings.left_position }}">
        <div class="dual-stiletto__text-box">
          {%- if section.settings.left_heading != blank -%}
            <h2 class="dual-stiletto__heading">{{ section.settings.left_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.left_description != blank -%}
            <p class="dual-stiletto__description">{{ section.settings.left_description | escape }}</p>
          {%- endif -%}
          {%- if section.settings.left_btn_label != blank -%}
            <a href="{{ section.settings.left_btn_link | default: '#' }}" class="dual-stiletto__btn"><span>{{ section.settings.left_btn_label | escape }}</span></a>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- comment -%} ---- RIGHT: Slideshow ---- {%- endcomment -%}
    <dual-slider-stiletto class="dual-stiletto__card dual-stiletto__card--right" data-speed="{{ section.settings.slide_speed }}">
      {%- for block in section.blocks -%}
        <div class="dual-stiletto__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 100vw, 50vw', widths: '375, 550, 750, 1000' }}
          {%- else -%}
            {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
      <div class="dual-stiletto__overlay" style="background: linear-gradient(to top, {{ section.settings.right_overlay_color | default: '#000000' | color_modify: 'alpha', section.settings.right_overlay_opacity | divided_by: 100.0 }} 0%, transparent 60%);">&nbsp;</div>
      <div class="dual-stiletto__content dual-stiletto__content--{{ section.settings.right_position }}" data-content>
        <div class="dual-stiletto__text-box">
          {%- for block in section.blocks -%}
            <div class="dual-stiletto__slide-content{% if forloop.first %} is-active{% endif %}" data-slide-content="{{ forloop.index0 }}" style="{% unless forloop.first %}display:none;{% endunless %}">
              {%- if block.settings.heading != blank -%}
                <h2 class="dual-stiletto__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="dual-stiletto__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
              {%- if block.settings.btn_label != blank -%}
                <a href="{{ block.settings.btn_link | default: '#' }}" class="dual-stiletto__btn"><span>{{ block.settings.btn_label | escape }}</span></a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </dual-slider-stiletto>

  </div>
</section>

<script>
  if (!customElements.get('dual-slider-stiletto')) {
    customElements.define('dual-slider-stiletto', class extends HTMLElement {
      connectedCallback() {
        this.slides = this.querySelectorAll('.dual-stiletto__slide');
        this.contents = this.querySelectorAll('[data-slide-content]');
        this.total = this.slides.length;
        this.current = 0;
        this.speed = (parseInt(this.getAttribute('data-speed')) || 5) * 1000;

        if (this.total <= 1) return;

        this.startAutoplay();
        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goTo(index) {
        this.slides[this.current].classList.remove('is-active');
        if (this.contents[this.current]) this.contents[this.current].style.display = 'none';

        this.current = ((index % this.total) + this.total) % this.total;

        this.slides[this.current].classList.add('is-active');
        if (this.contents[this.current]) this.contents[this.current].style.display = '';
      }

      startAutoplay() {
        this.stopAutoplay();
        this.interval = setInterval(() => this.goTo(this.current + 1), this.speed);
      }

      stopAutoplay() {
        if (this.interval) clearInterval(this.interval);
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    });
  }
</script>

