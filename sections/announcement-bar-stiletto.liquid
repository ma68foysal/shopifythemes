<style>
  .announcement-stiletto {
    position: relative;
    z-index: 101;
    overflow: hidden;
  }

  .announcement-stiletto__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
    min-height: 38px;
    position: relative;
  }

  /* Arrows */
  .announcement-stiletto__arrow {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    line-height: 1;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .announcement-stiletto__arrow:hover {
    opacity: 0.6;
  }

  .announcement-stiletto__arrow .svg-wrapper {
    display: flex;
    width: 10px;
    height: 10px;
  }

  .announcement-stiletto__arrow .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .announcement-stiletto__arrow--prev .svg-wrapper {
    transform: rotate(90deg);
  }

  .announcement-stiletto__arrow--next .svg-wrapper {
    transform: rotate(-90deg);
  }

  /* Slider viewport */
  .announcement-stiletto__slider {
    position: relative;
    overflow: hidden;
    flex: 1;
    max-width: 600px;
    text-align: center;
  }

  .announcement-stiletto__track {
    display: flex;
    transition: transform 0.4s ease;
    width: 100%;
  }

  .announcement-stiletto__slide {
    flex: 0 0 100%;
    width: 100%;
    min-width: 100%;
  }

  .announcement-stiletto__slide a {
    color: inherit;
    text-decoration: none;
  }

  .announcement-stiletto__slide a:hover {
    text-decoration: underline;
  }

  .announcement-stiletto__text {
    font-size: {{ section.settings.font_size }}px;
    letter-spacing: 0.04em;
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Only one slide = hide arrows */
  .announcement-stiletto[data-total="1"] .announcement-stiletto__arrow {
    display: none;
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    .announcement-stiletto__inner {
      padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
      gap: 10px;
    }

    .announcement-stiletto__text {
      font-size: {{ section.settings.font_size | minus: 1 }}px;
    }
  }
</style>

{%- if section.blocks.size > 0 -%}
  <announcement-bar-stiletto
    class="announcement-stiletto"
    style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
    data-total="{{ section.blocks.size }}"
    role="region"
    aria-label="{{ 'sections.header.announcement' | t }}"
  >
    <div class="announcement-stiletto__inner">
      {%- if section.blocks.size > 1 -%}
        <button
          class="announcement-stiletto__arrow announcement-stiletto__arrow--prev"
          aria-label="Previous announcement"
          data-prev
        >
          <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
        </button>
      {%- endif -%}

      <div class="announcement-stiletto__slider">
        <div class="announcement-stiletto__track" data-track>
          {%- for block in section.blocks -%}
            <div class="announcement-stiletto__slide" {{ block.shopify_attributes }}>
              {%- if block.settings.text != blank -%}
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">
                {%- endif -%}
                <p class="announcement-stiletto__text">{{ block.settings.text | escape }}</p>
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.blocks.size > 1 -%}
        <button
          class="announcement-stiletto__arrow announcement-stiletto__arrow--next"
          aria-label="Next announcement"
          data-next
        >
          <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
        </button>
      {%- endif -%}
    </div>
  </announcement-bar-stiletto>
{%- endif -%}

{% javascript %}
  class AnnouncementBarStilettoElement extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.slides = this.querySelectorAll('.announcement-stiletto__slide');
      this.total = this.slides.length;
      this.current = 0;
      this.autoplay = this.getAttribute('data-autoplay') === 'true';
      this.speed = (parseInt(this.getAttribute('data-speed')) || 5) * 1000;

      if (this.total <= 1) return;

      const prev = this.querySelector('[data-prev]');
      const next = this.querySelector('[data-next]');

      if (prev) prev.addEventListener('click', () => this.prev());
      if (next) next.addEventListener('click', () => this.next());

      if (this.autoplay) {
        this.startAutoplay();
        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }
    }

    goTo(index) {
      this.current = ((index % this.total) + this.total) % this.total;
      this.track.style.transform = `translateX(-${this.current * 100}%)`;
    }

    next() {
      this.goTo(this.current + 1);
    }

    prev() {
      this.goTo(this.current - 1);
    }

    startAutoplay() {
      this.stopAutoplay();
      this.interval = setInterval(() => this.next(), this.speed);
    }

    stopAutoplay() {
      if (this.interval) clearInterval(this.interval);
    }

    disconnectedCallback() {
      this.stopAutoplay();
    }
  }

  customElements.define('announcement-bar-stiletto', AnnouncementBarStilettoElement);
{% endjavascript %}

{% schema %}
{
  "name": "Announcement Stiletto",
  "class": "announcement-stiletto-section",
  "max_blocks": 8,

  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate announcements",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change announcement speed",
      "default": 5
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f0e1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders over $250",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Stiletto",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free shipping on orders over $250"
          }
        }
      ]
    }
  ]
}
{% endschema %}
