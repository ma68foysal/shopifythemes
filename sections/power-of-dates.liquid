{%- style -%}
  /* ========== POWER OF DATES ========== */
  .pod {
    --pod-text: {{ section.settings.text_color }};
    --pod-bg: {{ section.settings.bg_color }};
    --pod-heading-color: {{ section.settings.heading_color }};
    --pod-pt: {{ section.settings.padding_top }}px;
    --pod-pb: {{ section.settings.padding_bottom }}px;
  }
  .pod__wrapper {
    background: var(--pod-bg);
    overflow: hidden;
    padding: var(--pod-pt) 0 var(--pod-pb);
  }
  .pod__title {
    font-family: var(--font-heading-family);
    font-size: 28px;
    color: var(--pod-heading-color);
    text-transform: uppercase;
    text-align: center;
    letter-spacing: 0.06em;
    margin: 0;
    padding: 60px 20px 40px;
    font-weight: var(--font-heading-weight);
  }

  /* --- DESKTOP: pinned scene --- */
  .pod__scene {
    display: none;
  }
  @media (min-width: 990px) {
     .pod__title {
    
    font-size: 90px;
    ;
  }
    .pod__scene {
      display: flex;
      gap: 48px;
      max-width: var(--page-width, 1200px);
      margin: 0 auto;
      padding: 40px 20px;
      align-items: center;
      min-height: 80vh;
    }
  }

  /* Image column: stacked layers */
  .pod__image-col {
    flex: 0 0 50%;
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: 16px;
    overflow: hidden;
    max-height: 560px;
  }
  .pod__image-layer {
    position: absolute;
    inset: 0;
    overflow: hidden;
    will-change: clip-path;
  }
  .pod__image-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Text column: stacked text blocks */
  .pod__text-col {
    flex: 1;
    position: relative;
    min-height: 250px;
  }
  .pod__text-block {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  @media (min-width: 990px) {
    .pod__text-block {
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      transform: translateY(-50%);
    }
    .pod__text-block.is-active {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .pod__card-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(32px, 2.5vw, 64px);
    color: var(--pod-heading-color);
    font-weight: var(--font-heading-weight);
    text-transform: uppercase;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: 0.02em;
  }
  .pod__card-text {
    font-size: clamp(16px, 1.1vw, 20px);
    color: rgba(47,19,12,0.75);
    line-height: 1.75;
    margin: 0;
  }

  /* --- MOBILE: simple column --- */
  .pod__mobile {
    display: none;
    flex-direction: column;
    gap: 48px;
    padding: 0 20px 60px;
    max-width: 600px;
    margin: 0 auto;
  }
  @media (max-width: 989px) {
    .pod__mobile {
      display: flex;
    }
  }
  .pod__mobile-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .pod__mobile-image {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    max-height: 400px;
  }
  .pod__mobile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{%- endstyle -%}

{%- assign block_count = section.blocks.size -%}

<section class="pod" id="PowerOfDates-{{ section.id }}">
  <div class="pod__wrapper">
    {%- if section.settings.title != blank -%}
      <h2 class="pod__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <!-- ===== DESKTOP: GSAP pinned + clip-path reveal ===== -->
    <div class="pod__scene" data-pod-scene>
      <!-- Stacked images -->
      <div class="pod__image-col" data-pod-images>
        {%- for block in section.blocks -%}
          <div
            class="pod__image-layer"
            data-pod-layer="{{ forloop.index0 }}"
            style="z-index: {{ forloop.index }}; clip-path: {% if forloop.first %}polygon(0 0, 100% 0, 100% 100%, 0 100%){% else %}polygon(0 100%, 100% 100%, 100% 100%, 0 100%){% endif %};"
          >
            {%- if block.settings.image != blank -%}
              {%- assign ih = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: sizes: '45vw', widths: '375,550,800,1000', loading: 'lazy', height: ih }}
            {%- else -%}
              <div style="width:100%;height:100%;background:#c9b89d;display:flex;align-items:center;justify-content:center;">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <!-- Stacked text blocks -->
      <div class="pod__text-col">
        {%- for block in section.blocks -%}
          <div
            class="pod__text-block{% if forloop.first %} is-active{% endif %}"
            data-pod-text="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h3 class="pod__card-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="pod__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- ===== MOBILE: column layout ===== -->
    <div class="pod__mobile">
      {%- for block in section.blocks -%}
        <div class="pod__mobile-card" {{ block.shopify_attributes }}>
          <div class="pod__mobile-image">
            {%- if block.settings.image != blank -%}
              {%- assign mh = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: sizes: '90vw', widths: '375,550,600', loading: 'lazy', height: mh }}
            {%- else -%}
              <div style="width:100%;height:100%;background:#c9b89d;display:flex;align-items:center;justify-content:center;">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          <div>
            {%- if block.settings.heading != blank -%}
              <h3 class="pod__card-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="pod__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  var section = document.getElementById('PowerOfDates-{{ section.id }}');
  if (!section) return;
  var scene = section.querySelector('[data-pod-scene]');
  if (!scene) return;

  var layers = section.querySelectorAll('[data-pod-layer]');
  var textBlocks = section.querySelectorAll('[data-pod-text]');
  var total = layers.length;
  if (total < 2) return;

  var mm = gsap.matchMedia();

  mm.add('(min-width: 990px)', function() {

    /* Set each layer's image to a progressively zoomed scale */
    var zoomStep = 0.35;
    layers.forEach(function(layer, i) {
      var img = layer.querySelector('img');
      if (img) {
        gsap.set(img, { scale: 1 + (i * zoomStep) });
      }
    });

    var tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 5%',
        end: '+=' + (total * 100) + '%',
        pin: true,
        scrub: 1,
        anticipatePin: 1
      }
    });

    for (var i = 1; i < total; i++) {
      (function(idx) {
        tl.to(textBlocks[idx - 1], {
          opacity: 0,
          duration: 0.3
        });

        var proxy = { reveal: 0 };
        tl.to(proxy, {
          reveal: 100,
          duration: 1,
          ease: 'none',
          onUpdate: function() {
            var top = 100 - proxy.reveal;
            layers[idx].style.clipPath =
              'polygon(0 ' + top + '%, 100% ' + top + '%, 100% 100%, 0 100%)';
          }
        }, '<');

        tl.to(textBlocks[idx], {
          opacity: 1,
          duration: 0.3
        }, '-=0.3');

        tl.to({}, { duration: 0.3 });

      })(i);
    }

    tl.to({}, { duration: 0.5 });

    return function() {
      /* Cleanup on resize to mobile */
      layers.forEach(function(l, i) {
        l.style.clipPath = i === 0
          ? 'polygon(0 0, 100% 0, 100% 100%, 0 100%)'
          : 'polygon(0 100%, 100% 100%, 100% 100%, 0 100%)';
      });
      textBlocks.forEach(function(tb) {
        tb.classList.remove('is-active');
        tb.style.opacity = '';
      });
      if (textBlocks[0]) textBlocks[0].classList.add('is-active');
    };
  });

  /* Mobile: fade-in on scroll */
  mm.add('(max-width: 989px)', function() {
    section.querySelectorAll('.pod__mobile-card').forEach(function(card) {
      gsap.from(card, {
        opacity: 0,
        y: 40,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      });
    });
  });
});
</script>

{% schema %}
{
  "name": "Power of Dates",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ece3d5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2f130c"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2f130c"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
