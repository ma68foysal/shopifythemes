<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<style>
  .shoppable-stiletto {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .shoppable-stiletto__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: {{ section.settings.grid_gap }}px;
    align-items: center;
  }

  /* ---- Left: Image with hotspots ---- */
  .shoppable-stiletto__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .shoppable-stiletto__image-wrap img,
  .shoppable-stiletto__image-wrap svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Hotspot dot */
  .shoppable-stiletto__dot {
    position: absolute;
    width: 36px;
    height: 36px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 5;
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Inner dot (dark circle with icon) */
  .shoppable-stiletto__dot-inner {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    transition: transform 0.2s ease;
    background: rgba(255, 255, 255, 1);
  }



  .shoppable-stiletto__dot:hover .shoppable-stiletto__dot-inner {
    transform: scale(1.1);
  }

  /* Active ring */
  .shoppable-stiletto__dot-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 1);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .shoppable-stiletto__dot.is-active .shoppable-stiletto__dot-ring {
    opacity: 1;
  }

  /* Water drop pulse animation */
  .shoppable-stiletto__dot-pulse {
    position: absolute;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 1);
    z-index: 1;
    animation: shoppable-pulse 2.5s ease-out infinite;
  }

  .shoppable-stiletto__dot-pulse--delay {
    animation-delay: 1.2s;
  }

  @keyframes shoppable-pulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    100% {
      transform: scale(2.8);
      opacity: 0;
    }
  }

  /* ---- Right: Product slider ---- */
  .shoppable-stiletto__right {
    display: flex;
    flex-direction: column;
  }

  .shoppable-stiletto__header {
    margin-bottom: 4px;
  }

  .shoppable-stiletto__title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: 300;
    font-style: normal;
    margin: 0 0 4px;
    font-family: var(--font-heading-family);
    letter-spacing: 0.01em;
    color: {{ section.settings.text_color }};
  }

  .shoppable-stiletto__shop-link {
    font-size: 12px;
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.02em;
    transition: opacity 0.2s ease;
  }

  .shoppable-stiletto__shop-link:hover {
    opacity: 0.6;
  }

  /* Slider */
  .shoppable-stiletto__slider {
    position: relative;
    margin-top: 20px;
  }

  .shoppable-stiletto__slider-viewport {
    overflow: hidden;
  }

  .shoppable-stiletto__slider-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .shoppable-stiletto__slide {
    flex: 0 0 100%;
    min-width: 100%;
    padding: 0 8px;
  }

  /* Product card */
  .shoppable-stiletto__product-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    overflow: hidden;
    max-width: 300px;
    margin: 0 auto;
  }

  .shoppable-stiletto__product-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f5f5f5;
  }

  .shoppable-stiletto__product-image img,
  .shoppable-stiletto__product-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .shoppable-stiletto__product-card:hover .shoppable-stiletto__product-image img {
    transform: scale(1.04);
  }

  .shoppable-stiletto__product-info {
    padding: 16px;
    text-align: center;
  }

  .shoppable-stiletto__product-name {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 6px;
    color: {{ section.settings.text_color }};
  }

  .shoppable-stiletto__product-name a {
    color: inherit;
    text-decoration: none;
  }

  .shoppable-stiletto__product-price {
    font-size: 13px;
    margin: 0 0 12px;
    color: {{ section.settings.text_color }};
  }

  .shoppable-stiletto__product-price s {
    opacity: 0.5;
    margin-right: 4px;
  }

  .shoppable-stiletto__product-price .sale-price {
    color: #c0392b;
  }

  .shoppable-stiletto__product-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: {{ section.settings.text_color }};
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    position: relative;
  }

  .shoppable-stiletto__product-btn:hover {
    opacity: 0.6;
  }

  .shoppable-stiletto__product-btn .loading__spinner {
    width: 14px;
    height: 14px;
  }

  .shoppable-stiletto__product-btn .loading__spinner svg {
    width: 14px;
    height: 14px;
  }

  /* Slider with side arrows layout */
  .shoppable-stiletto__slider {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .shoppable-stiletto__slider-arrow {
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.15);
    width: 32px;
    height: 32px;
    cursor: pointer;
    padding: 0;
    color: {{ section.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .shoppable-stiletto__slider-arrow:disabled {
    opacity: 0.15;
    cursor: default;
  }

  .shoppable-stiletto__slider-arrow:hover:not(:disabled) {
    opacity: 0.6;
  }

  .shoppable-stiletto__slider-arrow svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .shoppable-stiletto__slider-count {
    font-size: 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.5;
    letter-spacing: 0.04em;
    text-align: right;
    margin-top: 10px;
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    .shoppable-stiletto__inner {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 30px;
    }

    .shoppable-stiletto__product-card {
      max-width: 260px;
    }
  }
</style>

<section class="shoppable-stiletto">
  <div class="shoppable-stiletto__inner">
    {%- comment -%} ---- LEFT: Image with hotspot dots ---- {%- endcomment -%}
    <div class="shoppable-stiletto__image-wrap">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 100vw, 55vw', widths: '375, 550, 750, 1000, 1200'
        }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        <button
          class="shoppable-stiletto__dot{% if forloop.first %} is-active{% endif %}"
          style="top: {{ block.settings.dot_y }}%; left: {{ block.settings.dot_x }}%;"
          data-dot-index="{{ forloop.index0 }}"
          aria-label="View {{ block.settings.product.title | default: block.settings.title | escape }}"
          {{ block.shopify_attributes }}
        >
          <span class="shoppable-stiletto__dot-ring"></span>
          <span class="shoppable-stiletto__dot-pulse"></span>
          <span class="shoppable-stiletto__dot-pulse shoppable-stiletto__dot-pulse--delay"></span>
          <span class="shoppable-stiletto__dot-inner"> </span>
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} ---- RIGHT: Product slider ---- {%- endcomment -%}
    <shoppable-slider-stiletto class="shoppable-stiletto__right" data-total="{{ section.blocks.size }}">
      <div class="shoppable-stiletto__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="shoppable-stiletto__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.shop_link_text != blank -%}
          <a href="{{ section.settings.shop_link_url | default: '#' }}" class="shoppable-stiletto__shop-link">
            {{- section.settings.shop_link_text | escape -}}
          </a>
        {%- endif -%}
      </div>

      <div class="shoppable-stiletto__slider">
        {%- if section.blocks.size > 1 -%}
          <button class="shoppable-stiletto__slider-arrow" data-prev aria-label="Previous" disabled>
            <svg viewBox="0 0 24 24">
              <path d="M19 12H5M5 12L12 19M5 12L12 5"/>
            </svg>
          </button>
        {%- endif -%}

        <div class="shoppable-stiletto__slider-viewport">
          <div class="shoppable-stiletto__slider-track" data-track>
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              <div class="shoppable-stiletto__slide" data-slide="{{ forloop.index0 }}">
                <div class="shoppable-stiletto__product-card">
                  <div class="shoppable-stiletto__product-image">
                    {%- if block.settings.custom_image != blank -%}
                      {{
                        block.settings.custom_image
                        | image_url: width: 600
                        | image_tag: loading: 'lazy', sizes: '300px', widths: '200, 300, 400, 600'
                      }}
                    {%- elsif product != blank and product.featured_image != blank -%}
                      {{
                        product.featured_image
                        | image_url: width: 600
                        | image_tag: loading: 'lazy', sizes: '300px', widths: '200, 300, 400, 600'
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <div class="shoppable-stiletto__product-info">
                    <p class="shoppable-stiletto__product-name">
                      {%- if product != blank -%}
                        <a href="{{ product.url }}">{{ block.settings.title | default: product.title | escape }}</a>
                      {%- else -%}
                        {{ block.settings.title | escape }}
                      {%- endif -%}
                    </p>
                    <p class="shoppable-stiletto__product-price">
                      {%- if product != blank -%}
                        {%- if product.compare_at_price > product.price -%}
                          <s>{{ product.compare_at_price | money }}</s>
                          <span class="sale-price">{{ product.price | money }}</span>
                        {%- else -%}
                          {{ product.price | money }}
                        {%- endif -%}
                      {%- else -%}
                        {{ block.settings.price | escape }}
                      {%- endif -%}
                    </p>
                    {%- if product != blank -%}
                      <modal-opener data-modal="#QuickAddModal-Shoppable-{{ section.id }}">
                        <button
                          class="shoppable-stiletto__product-btn"
                          type="button"
                          aria-haspopup="dialog"
                          data-product-url="{{ product.url }}"
                        >
                          Choose options
                          <div class="loading__spinner hidden">
                            <svg
                              aria-hidden="true"
                              focusable="false"
                              class="spinner"
                              viewBox="0 0 66 66"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                            </svg>
                          </div>
                        </button>
                      </modal-opener>
                    {%- elsif block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="shoppable-stiletto__product-btn">Choose options</a>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if section.blocks.size > 1 -%}
          <button class="shoppable-stiletto__slider-arrow" data-next aria-label="Next">
            <svg viewBox="0 0 24 24">
              <path d="M5 12H19M19 12L12 5M19 12L12 19"/>
            </svg>
          </button>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="shoppable-stiletto__slider-count" data-count>1 / {{ section.blocks.size }}</div>
      {%- endif -%}
    </shoppable-slider-stiletto>
  </div>
</section>

{% javascript %}
  class ShoppableSliderStilettoElement extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.slides = this.querySelectorAll('[data-slide]');
      this.dots = document.querySelectorAll('.shoppable-stiletto__dot');
      this.prevBtn = this.querySelector('[data-prev]');
      this.nextBtn = this.querySelector('[data-next]');
      this.countEl = this.querySelector('[data-count]');
      this.total = parseInt(this.getAttribute('data-total')) || 0;
      this.current = 0;

      if (this.total <= 0) return;

      // Dot clicks → jump slider
      this.dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = parseInt(dot.getAttribute('data-dot-index'));
          this.goTo(idx);
        });
      });

      // Arrow clicks
      if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.goTo(this.current - 1));
      if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.goTo(this.current + 1));

      // Touch swipe
      let startX = 0;
      this.track.addEventListener(
        'touchstart',
        (e) => {
          startX = e.touches[0].clientX;
        },
        { passive: true }
      );
      this.track.addEventListener(
        'touchend',
        (e) => {
          const diff = startX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 50) this.goTo(this.current + (diff > 0 ? 1 : -1));
        },
        { passive: true }
      );

      this.updateUI();
    }

    goTo(index) {
      this.current = Math.max(0, Math.min(this.total - 1, index));
      this.track.style.transform = 'translateX(-' + this.current * 100 + '%)';
      this.updateUI();
    }

    updateUI() {
      // Update dots
      this.dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === this.current);
      });

      // Update arrows
      if (this.prevBtn) this.prevBtn.disabled = this.current <= 0;
      if (this.nextBtn) this.nextBtn.disabled = this.current >= this.total - 1;

      // Update count
      if (this.countEl) this.countEl.textContent = this.current + 1 + ' / ' + this.total;
    }
  }

  customElements.define('shoppable-slider-stiletto', ShoppableSliderStilettoElement);
{% endjavascript %}

{%- comment -%} Quick Add Modal (Dawn built-in) {%- endcomment -%}
<quick-add-modal id="QuickAddModal-Shoppable-{{ section.id }}" class="quick-add-modal">
  <div role="dialog" aria-label="Product quick add" aria-modal="true" class="quick-add-modal__content" tabindex="-1">
    <button
      id="ModalClose-Shoppable-{{ section.id }}"
      class="quick-add-modal__toggle"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
    </button>
    <div id="QuickAddInfo-Shoppable-{{ section.id }}" class="quick-add-modal__content-info"></div>
  </div>
</quick-add-modal>

{% schema %}
{
  "name": "Shoppable Stiletto",
  "tag": "section",
  "class": "shoppable-feature-stiletto-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lookbook image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recreate the look"
    },
    {
      "type": "text",
      "id": "shop_link_text",
      "label": "Shop link text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "shop_link_url",
      "label": "Shop link URL"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading font size",
      "default": 28
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f7f4ef"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Gap between image and slider",
      "default": 48
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product_dot",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "header",
          "content": "Hotspot position"
        },
        {
          "type": "range",
          "id": "dot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal position (left)",
          "default": 40
        },
        {
          "type": "range",
          "id": "dot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical position (top)",
          "default": 35
        },
        {
          "type": "header",
          "content": "Product"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom product image",
          "info": "Overrides product image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Overrides product title"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Custom price",
          "info": "Used when no product is selected (e.g. $99.00)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Used when no product is selected"
