{%- style -%}
  /* ========== IMAGE SCROLL OVERLAY ========== */
  .iso {
    --iso-bg: {{ section.settings.bg_color }};
    --iso-text: {{ section.settings.text_color }};
    --iso-heading-color: {{ section.settings.heading_color }};
    position: relative;
    overflow: hidden;
    height: 52vh;
    min-height: 650px;
    background: var(--iso-bg);
  }

  /* Image columns — right side only */
  .iso__images {
    position: absolute;
    top: -100%;
    bottom: -100%;
    right: -5%;
    width: 70%;
    display: flex;
    gap: 10px;
    transform: rotate(333deg);
    transform-origin: center center;
  }

  /* Each column scrolls at different speed */
  .iso__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    will-change: transform;
  }

  .iso__img {
    flex-shrink: 0;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 8px;
    overflow: hidden;
  }
  .iso__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dark overlay */
  .iso__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 10, 5, 0.55);
    z-index: 2;
  }

  /* Text content */
  .iso__content {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 40px;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
  }
  @media (min-width: 750px) {
    .iso__content {
      padding: 60px 48px;
    }
  }
  .iso__subtitle {
    font-family: var(--font-heading-family);
    font-size: clamp(14px, 1vw, 18px);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #b58348;
    margin: 0 0 12px;
    font-weight: 400;
  }
  .iso__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(32px, 4.73vw, 90px);
    color: var(--iso-heading-color);
    font-weight: var(--font-heading-weight);
    text-transform: uppercase;
    line-height: 1.05;
    margin: 0 0 16px;
    max-width: 650px;
    font-style: normal;
  }
  .iso__description {
    font-size: clamp(16px, 1.1vw, 20px);
    color: var(--iso-text);
    line-height: 1.6;
    margin: 0;
    max-width: 420px;
  }

  @media (max-width: 749px) {
    .iso {
      height: 60vh;
      min-height: 300px;
    }
    .iso__images {
      width: 85%;
      right: -25%;
      top:-32%;
      bottom:0;
    }
    .iso__content {
      padding: 24px 20px;
    }
    .iso__subtitle {
      font-size: 9px;
      margin-bottom: 8px;
    }
    .iso__heading {
      font-size: 28px;
      margin-bottom: 12px;
      max-width: 260px;
    }
    .iso__description {
      font-size: 12px;
      max-width: 240px;
    }
  }
{%- endstyle -%}

<section class="iso" id="IsoScroll-{{ section.id }}">
  <!-- Scrolling image columns -->
  <div class="iso__images" data-iso-images>
    {%- for i in (1..3) -%}
      {%- assign col_block_start = i | minus: 1 | times: 3 -%}
      <div class="iso__col" data-iso-col data-iso-speed="{{ i | modulo: 2 | times: 2 | minus: 1 }}">
        {%- for j in (1..3) -%}
          {%- assign block_idx = col_block_start | plus: j | minus: 1 -%}
          <div class="iso__img">
            {%- if section.blocks[block_idx].settings.image != blank -%}
              {%- assign img = section.blocks[block_idx].settings.image -%}
              {{ img | image_url: width: 500 | image_tag: sizes: '20vw', widths: '200,300,400,500', loading: 'lazy' }}
            {%- elsif section.blocks.size > 0 and section.blocks[0].settings.image != blank -%}
              {%- assign img = section.blocks[0].settings.image -%}
              {{ img | image_url: width: 500 | image_tag: sizes: '20vw', widths: '200,300,400,500', loading: 'lazy' }}
            {%- else -%}
              <div style="width:100%;height:100%;background:#3d2014;">
                {{ 'product-' | append: j | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>

  <!-- Overlay -->
  <div class="iso__overlay">&nbsp;</div>

  <!-- Content -->
  <div class="iso__content">
    {%- if section.settings.subtitle != blank -%}
      <p class="iso__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="iso__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="iso__description">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    var section = document.getElementById('IsoScroll-{{ section.id }}');
    if (!section) return;

    var cols = section.querySelectorAll('[data-iso-col]');
    if (!cols.length) return;

    cols.forEach(function (col, i) {
      var direction = i % 2 === 0 ? 1 : -1;
      var distance = (300 + i * 80) * direction;

      gsap.fromTo(
        col,
        { y: -distance },
        {
          y: distance,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.1,
          },
        }
      );
    });
  });
</script>

{% schema %}
{
  "name": "Image Scroll Overlay",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a0a05"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "CRAFT CHOCOLATE REIMAGINED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "IMAGE WITH TEXT OVERLAY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review."
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 15,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Scroll Overlay",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
