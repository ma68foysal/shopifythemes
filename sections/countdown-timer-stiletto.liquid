<style>
  .countdown-stiletto {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: #fff;
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }

  .countdown-stiletto__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 20px 64px;
    background-color: {{ section.settings.bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.gap }}px;
    flex-wrap: wrap;
  }

  /* Heading */
  .countdown-stiletto__heading {
    font-size: clamp(18px, {{ section.settings.heading_size }}px, 36px);
    font-weight: 300;
    font-style: normal;
    margin: 0;
    font-family: var(--font-heading-family);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  /* Timer */
  .countdown-stiletto__timer {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .countdown-stiletto__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 {{ section.settings.unit_padding }}px;
    position: relative;
  }

  .countdown-stiletto__unit:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 40px;
    background: {{ section.settings.text_color }};
    opacity: 0.2;
  }

  .countdown-stiletto__number {
    font-size: clamp(28px, {{ section.settings.number_size }}px, 64px);
    font-weight: 300;
    line-height: 1;
    font-family: var(--font-heading-family);
    letter-spacing: -0.02em;
  }

  .countdown-stiletto__label {
    font-size: {{ section.settings.label_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 4px;
    opacity: 0.7;
  }

  /* Promo text */
  .countdown-stiletto__promo {
    font-size: {{ section.settings.promo_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  /* Button */
  .countdown-stiletto__btn {
    display: inline-block;
    text-decoration: none;
    font-size: {{ section.settings.button_font_size }}px;
    letter-spacing: 0.06em;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    border: none;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .countdown-stiletto__btn:hover {
    opacity: 0.85;
  }

  /* Expired */
  .countdown-stiletto__expired {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 300;
    font-style: normal;
    font-family: var(--font-heading-family);
  }

  /* Responsive */
  @media screen and (max-width: 989px) {
    .countdown-stiletto__inner {
      padding: 20px 24px;
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .countdown-stiletto__inner {
      flex-direction: column;
      text-align: center;
      gap: 16px;
      padding: 20px 16px;
    }

    .countdown-stiletto__heading {
      white-space: normal;
      word-break: break-word;
    }

    .countdown-stiletto__timer {
      gap: 0;
    }

    .countdown-stiletto__unit {
      padding: 0 10px;
    }
  }
</style>

<section id='countdown-{{ section.id }}' class="countdown-stiletto">
  <div class="countdown-stiletto__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="countdown-stiletto__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <countdown-timer-stiletto class="countdown-stiletto__timer" data-end="{{ section.settings.end_date }}T{{ section.settings.end_time }}:00">
      <div class="countdown-stiletto__unit" data-days>
        <span class="countdown-stiletto__number">0</span>
        <span class="countdown-stiletto__label">Days</span>
      </div>
      <div class="countdown-stiletto__unit" data-hours>
        <span class="countdown-stiletto__number">0</span>
        <span class="countdown-stiletto__label">Hours</span>
      </div>
      <div class="countdown-stiletto__unit" data-minutes>
        <span class="countdown-stiletto__number">0</span>
        <span class="countdown-stiletto__label">Minutes</span>
      </div>
      <div class="countdown-stiletto__unit" data-seconds>
        <span class="countdown-stiletto__number">0</span>
        <span class="countdown-stiletto__label">Seconds</span>
      </div>
    </countdown-timer-stiletto>

    {%- if section.settings.promo_text != blank -%}
      <p class="countdown-stiletto__promo">{{ section.settings.promo_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="countdown-stiletto__btn">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}

  </div>
</section>

<script>
(function(){

function initCountdown(sectionId){
console.log('logs', sectionId)
  const section = document.getElementById(sectionId);
  if(!section) return;

  const timer = section.querySelector('[data-end]');
  if(!timer) return;

  const endString = timer.getAttribute('data-end');
  const endDate = new Date(endString);

  if(isNaN(endDate)){
    console.warn('Invalid countdown date:', endString);
    return;
  }

  const daysEl = timer.querySelector('[data-days] .countdown-stiletto__number');
  const hoursEl = timer.querySelector('[data-hours] .countdown-stiletto__number');
  const minutesEl = timer.querySelector('[data-minutes] .countdown-stiletto__number');
  const secondsEl = timer.querySelector('[data-seconds] .countdown-stiletto__number');

  let interval; // ✅ declare first

  function update(){

    const now = Date.now();
    const distance = endDate - now;

    if(distance <= 0){
      clearInterval(interval);
      if(daysEl) daysEl.textContent = '0';
      if(hoursEl) hoursEl.textContent = '0';
      if(minutesEl) minutesEl.textContent = '0';
      if(secondsEl) secondsEl.textContent = '0';
      return;
    }

    const days = Math.floor(distance / 86400000);
    const hours = Math.floor((distance % 86400000) / 3600000);
    const minutes = Math.floor((distance % 3600000) / 60000);
    const seconds = Math.floor((distance % 60000) / 1000);

    if(daysEl) daysEl.textContent = days;
    if(hoursEl) hoursEl.textContent = hours;
    if(minutesEl) minutesEl.textContent = minutes;
    if(secondsEl) secondsEl.textContent = seconds;
  }

  interval = setInterval(update,1000); // ✅ define interval
  update(); // run immediately
}

/* Page load */
document.addEventListener('DOMContentLoaded',function(){
  
  initCountdown('countdown-{{ section.id }}');
});

/* Shopify editor reload */
document.addEventListener('shopify:section:load',function(e){
  if(e.target.id === 'countdown-{{ section.id }}'){
    initCountdown('countdown-{{ section.id }}');
  }
});

})();
</script>

