{%- style -%}
  #CustomFooter-{{ section.id }} {
    --footer-bg: {{ section.settings.bg_color }};
    --footer-text: {{ section.settings.text_color }};
    --footer-heading-color: {{ section.settings.heading_color }};
    --footer-link-hover: {{ section.settings.link_hover_color }};
    --footer-divider: {{ section.settings.divider_color }};
    --footer-btn-bg: {{ section.settings.back_to_top_bg }};
    --footer-btn-text: {{ section.settings.back_to_top_text }};
    --footer-pt: {{ section.settings.padding_top }}px;
    --footer-pb: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #CustomFooter-{{ section.id }} {
      --footer-pt: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --footer-pb: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div id="CustomFooter-{{ section.id }}" class="custom-footer">
  <div class="custom-footer__padding">
    <div class="custom-footer__inner page-width">

      {%- comment -%} Back to Top {%- endcomment -%}
      {%- if section.settings.show_back_to_top -%}
        <div class="custom-footer__back-top">
          <button class="custom-footer__back-top-btn" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Back to top">
            <span>BACK TO TOP</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- comment -%} Top Row: Logo + Social/Badge {%- endcomment -%}
      <div class="custom-footer__top">
        <div class="custom-footer__logo">
          {%- if section.settings.logo != blank -%}
            <a href="{{ routes.root_url }}">
              {{
                section.settings.logo
                | image_url: width: 400
                | image_tag:
                    loading: 'lazy',
                    widths: '150, 200, 300, 400',
                    sizes: '20rem',
                    alt: shop.name
              }}
            </a>
          {%- else -%}
            <a href="{{ routes.root_url }}" class="custom-footer__logo-text">{{ shop.name }}</a>
          {%- endif -%}
        </div>

        <div class="custom-footer__top-right">
          {%- if section.settings.show_social -%}
            <div class="custom-footer__social">
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="custom-footer__social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="custom-footer__social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter" class="custom-footer__social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="custom-footer__social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="custom-footer__social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.38-6.2V9.14a8.16 8.16 0 0 0 3.84.96V6.69z"/></svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.badge_image != blank -%}
            <div class="custom-footer__badge">
              {{
                section.settings.badge_image
                | image_url: width: 160
                | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '6rem', alt: 'Partner badge'
              }}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Menu Columns {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="custom-footer__menus">
          {%- for block in section.blocks -%}
            <div class="custom-footer__menu-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h4 class="custom-footer__menu-heading">{{ block.settings.heading }}</h4>
              {%- endif -%}

              {%- if block.settings.menu != blank -%}
                <ul class="custom-footer__menu-list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .custom-footer {
    background-color: var(--footer-bg, #0a0a0a);
    color: var(--footer-text, #ffffff);
  }

  .custom-footer__padding {
    padding-top: var(--footer-pt, 60px);
    padding-bottom: var(--footer-pb, 60px);
  }

  .custom-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;
  }

  /* ---- Back to Top ---- */
  .custom-footer__back-top {
    display: flex;
    justify-content: center;
    margin-bottom: 1.6rem;
  }

  .custom-footer__back-top-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 3rem;
    border-radius: 100px;
    background-color: var(--footer-btn-bg, #1a1a1a);
    color: var(--footer-btn-text, #ffffff);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
    transition: all 0.3s ease;
    line-height: 1;
  }

  .custom-footer__back-top-btn:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .custom-footer__back-top-btn svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  /* ---- Logo Row ---- */
  .custom-footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .custom-footer__logo a {
    display: inline-block;
  }

  .custom-footer__logo img {
    height: 2.8rem;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .custom-footer__logo-text {
    font-size: 2.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--footer-heading-color, #ffffff);
    text-decoration: none;
    font-family: var(--font-heading-family, serif);
  }

  .custom-footer__top-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  /* Social icons — boxed style to match reference */
  .custom-footer__social {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .custom-footer__social-link {
    color: var(--footer-text, #ffffff);
    transition: opacity 0.3s ease, background-color 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-right: none;
  }

  .custom-footer__social-link:first-child {
    border-radius: 6px 0 0 6px;
  }

  .custom-footer__social-link:last-child {
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0 6px 6px 0;
  }

  .custom-footer__social-link:only-child {
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
  }

  .custom-footer__social-link:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .custom-footer__social-link svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  /* Badge — boxed to match social icons height */
  .custom-footer__badge {
    height: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    display: flex;
    align-items: center;
    background-color: var(--footer-text);
  }

  .custom-footer__badge img {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  /* ---- Menu Columns ---- */
  .custom-footer__menus {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    padding-top: 3.2rem;
    border-top: 1px solid var(--footer-divider, #222222);
    max-width: 72rem;
  }

  .custom-footer__menu-heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.6rem;
    color: var(--footer-heading-color, #ffffff);
  }

  .custom-footer__menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .custom-footer__menu-list a {
    color: var(--footer-text, #ffffff);
    text-decoration: none;
    font-size: 1.3rem;
    opacity: 0.45;
    transition: opacity 0.3s ease, color 0.3s ease;
  }

  .custom-footer__menu-list a:hover {
    opacity: 1;
    color: var(--footer-link-hover, #ff4500);
  }

  /* ---- Tablet+ (750px) ---- */
  @media screen and (min-width: 750px) {
    .custom-footer__menus {
      grid-template-columns: repeat(3, 1fr);
      gap: 4rem;
    }

    .custom-footer__logo img {
      height: 3.2rem;
    }

    .custom-footer__logo-text {
      font-size: 3rem;
    }
  }

  /* ---- Desktop (990px) ---- */
  @media screen and (min-width: 990px) {
    .custom-footer__inner {
      gap: 3.6rem;
    }

    .custom-footer__menus {
      gap: 6rem;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Back to top"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show Back to Top button",
      "default": true
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo",
      "info": "Displayed as white. Recommended: transparent PNG"
    },
    {
      "type": "header",
      "content": "Social & Badge"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "info": "Uses social links from theme settings"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Partner badge image",
      "info": "E.g. Shopify Plus Partner badge"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#ff4500"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "back_to_top_bg",
      "label": "Back to top button bg",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "back_to_top_text",
      "label": "Back to top button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Services"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer",
          "info": "Select a navigation menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Services" } },
        { "type": "menu_column", "settings": { "heading": "Information" } },
        { "type": "menu_column", "settings": { "heading": "Markets" } }
      ]
    }
  ]
}
{% endschema %}
