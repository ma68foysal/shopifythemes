<style>
  .marquee-stiletto {
    overflow: hidden;
    white-space: nowrap;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .marquee-stiletto__track {
    display: inline-flex;
    animation: marquee-stiletto-scroll {{ section.settings.speed }}s linear infinite;
  }

  .marquee-stiletto__track:hover {
    animation-play-state: paused;
  }

  .marquee-stiletto__item {
    display: inline-flex;
    align-items: center;
    gap: {{ section.settings.separator_gap }}px;
    padding: 0 {{ section.settings.separator_gap }}px;
    font-size: {{ section.settings.font_size }}px;
    letter-spacing: {{ section.settings.letter_spacing }}em;
    text-transform: {{ section.settings.text_transform }};
    white-space: nowrap;
  }

  .marquee-stiletto__item a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .marquee-stiletto__item a:hover {
    opacity: 0.7;
  }

  .marquee-stiletto__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    flex-shrink: 0;
  }

  @keyframes marquee-stiletto-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  {%- if section.settings.direction == 'right' -%}
    .marquee-stiletto__track {
      animation-direction: reverse;
    }
  {%- endif -%}
</style>

{%- if section.blocks.size > 0 -%}
  <div class="marquee-stiletto" role="marquee" aria-label="Announcements">
    <div class="marquee-stiletto__track">
      {%- comment -%} Repeat blocks twice for seamless infinite loop {%- endcomment -%}
      {%- for repeat in (1..2) -%}
        {%- for block in section.blocks -%}
          <span class="marquee-stiletto__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
            {%- else -%}
              {{ block.settings.text | escape }}
            {%- endif -%}
            <span class="marquee-stiletto__dot"></span>
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Slider Stiletto",
  "tag": "section",
  "class": "marquee-slider-stiletto-section",
  "settings": [
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll speed",
      "default": 20,
      "info": "Lower = faster"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#b8a97e"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Separator dot color",
      "default": "#b8a97e"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 13
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Letter spacing",
      "default": 4,
      "info": "In hundredths of em"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "separator_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Gap between items",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "End of season sale"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Slider Stiletto",
      "blocks": [
        { "type": "text", "settings": { "text": "End of season sale" } },
        { "type": "text", "settings": { "text": "Shop the sale" } },
        { "type": "text", "settings": { "text": "End of season sale" } },
        { "type": "text", "settings": { "text": "Shop the sale" } }
      ]
    }
  ]
}
{% endschema %}
