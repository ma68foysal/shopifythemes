<style>
  .philosophy-stiletto {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  .philosophy-stiletto__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ---- Top: Philosophy text ---- */
  .philosophy-stiletto__subtitle {
    font-size: {{ section.settings.subtitle_font_size }}px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 20px;
    font-weight: 400;
  }

  .philosophy-stiletto__heading {
    font-size: clamp(24px, {{ section.settings.heading_font_size }}px, 52px);
    font-weight: 300;
    font-style: normal;
    line-height: 1.25;
    margin: 0 0 24px;
    max-width: 800px;
    font-family: var(--font-heading-family);
    letter-spacing: 0.01em;
  }

  .philosophy-stiletto__link {
    display: inline-block;
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    text-underline-offset: 4px;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: opacity 0.2s ease;
  }

  .philosophy-stiletto__link:hover {
    opacity: 0.6;
  }

  /* ---- Divider ---- */
  .philosophy-stiletto__divider {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin: {{ section.settings.divider_spacing }}px 0;
  }

  /* ---- Bottom: Collection slider ---- */
  .philosophy-stiletto__slider-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .philosophy-stiletto__slider-title {
    font-size: {{ section.settings.slider_title_font_size }}px;
    font-weight: 300;
    font-style: normal;
    margin: 0;
    font-family: var(--font-heading-family);
    letter-spacing: 0.01em;
  }

  .philosophy-stiletto__slider-arrows {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .philosophy-stiletto__arrow {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ section.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .philosophy-stiletto__arrow:hover {
    opacity: 0.5;
  }

  .philosophy-stiletto__arrow:disabled {
    opacity: 0.2;
    cursor: default;
  }

  .philosophy-stiletto__arrow svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  /* Slider track */
  .philosophy-stiletto__slider-viewport {
    overflow: hidden;
  }

  .philosophy-stiletto__slider-track {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    transition: transform 0.4s ease;
  }

  .philosophy-stiletto__card {
    flex: 0 0 calc((100% - {{ section.settings.card_gap | times: section.settings.cards_per_row | minus: section.settings.card_gap }}px) / {{ section.settings.cards_per_row }});
    min-width: 0;
  }

  .philosophy-stiletto__card-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ section.settings.card_aspect_ratio }};
    background: #eee;
    {% comment %} margin-bottom: 12px; {% endcomment %}
  }

  .philosophy-stiletto__card-image img,
  .philosophy-stiletto__card-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .philosophy-stiletto__card:hover .philosophy-stiletto__card-image img {
    transform: scale(1.04);
  }

  .philosophy-stiletto__card-image a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .philosophy-stiletto__card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #242526;
    color: #fff;
}

  .philosophy-stiletto__card-title {
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin: 0;
    font-family:var(--font-heading-family);
  }

  .philosophy-stiletto__card-title a {
    color: inherit;
    text-decoration: none;
  }

  .philosophy-stiletto__card-arrow {
    display: flex;
    color: {{ section.settings.text_color }};
  }

  .philosophy-stiletto__card-arrow svg {
    width: 16px;
    height: 16px;
    fill: #fff;
    stroke: currentColor;
    stroke-width: 1.5;
    color:#fff;
  }

  /* Responsive */
  @media screen and (max-width: 989px) {
    .philosophy-stiletto__inner {
      padding: 0 24px;
    }

    .philosophy-stiletto__card {
      flex: 0 0 calc((100% - {{ section.settings.card_gap }}px) / 2.3);
    }
  }

  @media screen and (max-width: 549px) {
    .philosophy-stiletto__card {
      flex: 0 0 calc(100% - 40px);
    }

    .philosophy-stiletto__heading {
      font-size: 24px;
    }
  }
</style>

<section class="philosophy-stiletto">
  <div class="philosophy-stiletto__inner">

    {%- comment -%} ---- Philosophy text ---- {%- endcomment -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="philosophy-stiletto__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="philosophy-stiletto__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.link_text != blank -%}
      <a href="{{ section.settings.link_url | default: '#' }}" class="philosophy-stiletto__link">{{ section.settings.link_text | escape }}</a>
    {%- endif -%}

    {%- comment -%} ---- Divider ---- {%- endcomment -%}
    {%- if section.settings.show_divider -%}
      <hr class="philosophy-stiletto__divider">
    {%- endif -%}

    {%- comment -%} ---- Collection slider ---- {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <philosophy-slider class="philosophy-stiletto__slider" data-cards-per-row="{{ section.settings.cards_per_row }}" data-gap="{{ section.settings.card_gap }}">

        <div class="philosophy-stiletto__slider-header">
          {%- if section.settings.slider_title != blank -%}
            <h3 class="philosophy-stiletto__slider-title">{{ section.settings.slider_title }}</h3>
          {%- endif -%}

          {%- if section.blocks.size > section.settings.cards_per_row -%}
            <div class="philosophy-stiletto__slider-arrows">
              <button class="philosophy-stiletto__arrow" data-prev aria-label="Previous" disabled>
                <svg viewBox="0 0 24 24"><path d="M19 12H5M5 12L12 19M5 12L12 5"/></svg>
              </button>
              <button class="philosophy-stiletto__arrow" data-next aria-label="Next">
                <svg viewBox="0 0 24 24"><path d="M5 12H19M19 12L12 5M19 12L12 19"/></svg>
              </button>
            </div>
          {%- endif -%}
        </div>

        <div class="philosophy-stiletto__slider-viewport">
          <div class="philosophy-stiletto__slider-track" data-track>
            {%- for block in section.blocks -%}
              <div class="philosophy-stiletto__card" {{ block.shopify_attributes }}>
                <div class="philosophy-stiletto__card-image">
                  {%- if block.settings.collection != blank -%}
                    <a href="{{ block.settings.collection.url }}">
                  {%- elsif block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}">
                  {%- endif -%}

                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(max-width: 549px) 80vw, (max-width: 989px) 40vw, 25vw', widths: '200, 300, 400, 500, 600' }}
                    {%- elsif block.settings.collection != blank and block.settings.collection.image != blank -%}
                      {{ block.settings.collection.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(max-width: 549px) 80vw, (max-width: 989px) 40vw, 25vw', widths: '200, 300, 400, 500, 600' }}
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}

                  {%- if block.settings.collection != blank or block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </div>

                <div class="philosophy-stiletto__card-bottom">
                  <p class="philosophy-stiletto__card-title">
                    {%- if block.settings.collection != blank -%}
                      <a href="{{ block.settings.collection.url }}">{{ block.settings.title | default: block.settings.collection.title | escape }}</a>
                    {%- elsif block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}">{{ block.settings.title | escape }}</a>
                    {%- else -%}
                      {{ block.settings.title | escape }}
                    {%- endif -%}
                  </p>
                  {%- if block.settings.collection != blank or block.settings.link != blank -%}
                    <span class="philosophy-stiletto__card-arrow">
                      <svg viewBox="0 0 24 24"><path d="M5 12H19M19 12L12 5M19 12L12 19"/></svg>
                    </span>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

      </philosophy-slider>
    {%- endif -%}

  </div>
</section>

{% javascript %}
  class PhilosophySlider extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.prevBtn = this.querySelector('[data-prev]');
      this.nextBtn = this.querySelector('[data-next]');
      this.cards = this.querySelectorAll('.philosophy-stiletto__card');
      this.perRow = parseInt(this.getAttribute('data-cards-per-row')) || 5;
      this.gap = parseInt(this.getAttribute('data-gap')) || 16;
      this.position = 0;

      if (!this.prevBtn || !this.nextBtn || this.cards.length <= this.perRow) return;

      this.maxPosition = this.cards.length - this.perRow;

      this.prevBtn.addEventListener('click', () => this.move(-1));
      this.nextBtn.addEventListener('click', () => this.move(1));

      // Touch swipe
      let startX = 0;
      this.track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
      this.track.addEventListener('touchend', (e) => {
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) this.move(diff > 0 ? 1 : -1);
      }, { passive: true });

      // Recalc on resize
      this.resizeObserver = new ResizeObserver(() => this.updatePerRow());
      this.resizeObserver.observe(this);
      this.updateButtons();
    }

    updatePerRow() {
      const width = this.offsetWidth;
      if (width < 550) {
        this.currentPerRow = 1;
      } else if (width < 990) {
        this.currentPerRow = 2;
      } else {
        this.currentPerRow = this.perRow;
      }
      this.maxPosition = Math.max(0, this.cards.length - this.currentPerRow);
      if (this.position > this.maxPosition) {
        this.position = this.maxPosition;
        this.updateTrack();
      }
      this.updateButtons();
    }

    move(dir) {
      this.position = Math.max(0, Math.min(this.maxPosition, this.position + dir));
      this.updateTrack();
      this.updateButtons();
    }

    updateTrack() {
      if (!this.cards[0]) return;
      const cardWidth = this.cards[0].offsetWidth + this.gap;
      this.track.style.transform = `translateX(-${this.position * cardWidth}px)`;
    }

    updateButtons() {
      if (this.prevBtn) this.prevBtn.disabled = this.position <= 0;
      if (this.nextBtn) this.nextBtn.disabled = this.position >= this.maxPosition;
    }

    disconnectedCallback() {
      if (this.resizeObserver) this.resizeObserver.disconnect();
    }
  }

  customElements.define('philosophy-slider', PhilosophySlider);
{% endjavascript %}

{% schema %}
{
  "name": "Philosophy Stiletto",
  "tag": "section",
  "class": "philosophy-stiletto-section",
  "settings": [
    {
      "type": "header",
      "content": "Philosophy text"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "OUR PHILOSOPHY"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Our effortless yet distinctive pieces are designed to be mixed & matched, worn together to transform an outfit into an art of functional self-expression.</p>"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Read more"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "default": true,
      "label": "Show divider line"
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Divider spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Collection slider"
    },
    {
      "type": "text",
      "id": "slider_title",
      "label": "Slider title",
      "default": "Find the perfect piece"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Cards per row (desktop)",
      "default": 5
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 16
    },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "label": "Card image ratio",
      "options": [
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "2 / 3", "label": "Tall portrait (2:3)" },
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Classic (4:5)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Subtitle font size",
      "default": 12
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 24,
      "max": 52,
      "step": 2,
      "unit": "px",
      "label": "Heading font size",
      "default": 38
    },
    {
      "type": "range",
      "id": "slider_title_font_size",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Slider title font size",
      "default": 26
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f7f4ef"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides collection image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Overrides collection title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Overrides collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Philosophy Stiletto",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Trousers" } },
        { "type": "collection_card", "settings": { "title": "Dresses" } },
        { "type": "collection_card", "settings": { "title": "Jackets" } },
        { "type": "collection_card", "settings": { "title": "Knitwear" } },
        { "type": "collection_card", "settings": { "title": "Minis" } }
      ]
    }
  ]
}
{% endschema %}
