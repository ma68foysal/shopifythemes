        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-pinterest.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-tiktok.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" aria-label="Twitter" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-twitter.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" aria-label="YouTube" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-youtube.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_snapchat_link != blank -%}
          <a href="{{ settings.social_snapchat_link }}" aria-label="Snapchat" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-snapchat.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_tumblr_link != blank -%}
          <a href="{{ settings.social_tumblr_link }}" aria-label="Tumblr" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-tumblr.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_vimeo_link != blank -%}
          <a href="{{ settings.social_vimeo_link }}" aria-label="Vimeo" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-vimeo.svg' | inline_asset_content }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

