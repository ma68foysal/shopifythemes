<style>
  /* ============================================
     Header Stiletto - Transparent Overlay Header
     ============================================ */

  .header-stiletto-wrapper {
    display: block;
    position: relative;
    width: 100%;
    z-index: 100;
    background-color: transparent;
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .header-stiletto-wrapper.is-scrolled,
  .header-stiletto-wrapper.is-mega-open,
  .header-stiletto-wrapper:hover {
    overflow: visible;
  }

  /* Sticky on scroll */
  .header-stiletto-wrapper.is-scrolled {
    position: fixed;
    top: 0;
    left: 0;
    background-color: #fff;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .header-stiletto-wrapper.is-scrolled .header-stiletto__top-menu li a,
  .header-stiletto-wrapper.is-scrolled .header-stiletto__nav-link,
  .header-stiletto-wrapper.is-scrolled .header-stiletto__nav-summary,
  .header-stiletto-wrapper.is-scrolled .header-stiletto__logo a,
  .header-stiletto-wrapper.is-scrolled .header-stiletto__logo .h2 {
    color: #1a1a1a;
  }

  /* Hover on header = white background */
  .header-stiletto-wrapper:hover {
    background-color: #fff;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .header-stiletto-wrapper:hover .header-stiletto__top-menu li a,
  .header-stiletto-wrapper:hover .header-stiletto__nav-link,
  .header-stiletto-wrapper:hover .header-stiletto__nav-summary,
  .header-stiletto-wrapper:hover .header-stiletto__logo a,
  .header-stiletto-wrapper:hover .header-stiletto__logo .h2 {
    color: #1a1a1a;
  }

  .header-stiletto-wrapper:hover .header-stiletto__nav-link:hover,
  .header-stiletto-wrapper:hover .header-stiletto__nav-summary:hover {
    color: #666;
  }

  .header-stiletto-wrapper:hover .header-stiletto__right-icons a,
  .header-stiletto-wrapper:hover .header-stiletto__mobile-toggle {
    color: #1a1a1a;
  }

  .header-stiletto-wrapper:hover .header-stiletto__cart-count {
    background: #1a1a1a;
    color: #fff;
  }

  /* Mega menu open = white background */
  .header-stiletto-wrapper.is-mega-open {
    background-color: #fff;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .header-stiletto-wrapper.is-mega-open .header-stiletto__top-menu li a,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__nav-link,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__nav-summary,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__logo a,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__logo .h2 {
    color: #1a1a1a;
  }

  .header-stiletto-wrapper.is-mega-open .header-stiletto__nav-link:hover,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__nav-summary:hover {
    color: #666;
  }

  .header-stiletto-wrapper.is-mega-open .header-stiletto__right-icons a,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__mobile-toggle {
    color: #1a1a1a;
  }

  .header-stiletto-wrapper.is-mega-open .header-stiletto__cart-count {
    background: #1a1a1a;
    color: #fff;
  }

  .header-stiletto-wrapper.is-scrolled .header-stiletto__right-icons a {
    color: #1a1a1a;
  }

  .header-stiletto-wrapper.is-scrolled .header-stiletto__cart-count {
    background: #1a1a1a;
    color: #fff;
  }

  /* ---- Top utility bar (text links only) ---- */
  .header-stiletto__top-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: {{ section.settings.padding_top }}px 40px 4px;
  }

  .header-stiletto__top-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-stiletto__top-menu li a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: {{ section.settings.top_menu_font_size }}px;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  .header-stiletto__top-menu li a:hover {
    color: #fff;
  }

  /* Cart count bubble */
  .header-stiletto__cart-count {
    position: absolute;
    top: -5px;
    right: -7px;
    background: #fff;
    color: #000;
    font-size: 9px;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .header-stiletto__icon-wrap {
    position: relative;
    display: flex;
  }

  /* ---- Main header row: logo | nav | icons ---- */
  .header-stiletto__main {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 6px 40px {{ section.settings.padding_bottom }}px;
    gap: 20px;
  }

  /* Logo */
  .header-stiletto__logo {
    justify-self: start;
  }

  .header-stiletto__logo a {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #fff;
    transition: color 0.3s ease;
  }

  .header-stiletto__logo img {
    max-height: 44px;
    width: auto;
  }

  .header-stiletto__logo .h2 {
    color: #fff;
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
    font-family: var(--font-heading-family);
    transition: color 0.3s ease;
  }

  /* ---- Right side icons (search, account, cart) ---- */
  .header-stiletto__right-icons {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: {{ section.settings.icon_gap }}px;
  }

  .header-stiletto__right-icons a {
    color: #fff;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header-stiletto__right-icons a:hover {
    opacity: 0.7;
  }

  .header-stiletto__right-icons .svg-wrapper {
    display: flex;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
  }

  .header-stiletto__right-icons .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }


  /* ---- Center navigation ---- */
  .header-stiletto__nav {
    justify-self: center;
  }

  .header-stiletto__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .header-stiletto__nav-item {
    position: relative;
  }

  .header-stiletto__nav-item--mega-full {
    position: static;
  }

  /* Simple dropdown items need relative positioning */
  .header-stiletto__nav-item--dropdown {
    position: relative;
  }

  .header-stiletto__nav-link,
  .header-stiletto__nav-summary {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #fff;
    text-decoration: none;
    font-size: {{ section.settings.nav_font_size }}px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 14px;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.3s ease;
    font-family: inherit;
    font-weight: inherit;
    line-height: inherit;
    list-style: none;
    white-space: nowrap;
  }

  .header-stiletto__nav-link:hover,
  .header-stiletto__nav-summary:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  .header-stiletto__nav-summary .svg-wrapper {
    display: flex;
    width: 7px;
    height: 7px;
    transition: transform 0.25s ease;
  }

  .header-stiletto__nav-summary .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .header-stiletto__nav-item.is-open .header-stiletto__nav-summary .svg-wrapper {
    transform: rotate(180deg);
  }

  /* ---- Mega Menu Dropdown ---- */
  .header-stiletto__mega-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: var(--mega-menu-width, 100%);
    background: #fff;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    padding: 36px 0 40px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
    z-index: 200;
  }

  .header-stiletto__nav-item.is-open > .header-stiletto__mega-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Full-width mode: stretch across entire header */
  .header-stiletto__nav-item--mega-full > .header-stiletto__mega-dropdown {
    left: 0;
    right: 0;
    width: 100%;
  }

  .header-stiletto__mega-inner {
    display: flex;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 40px;
    gap: 50px;
  }

  /* Menu columns (left side) */
  .header-stiletto__mega-links {
    display: flex;
    gap: 40px;
    flex: 1;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-stiletto__mega-col {
    min-width: 120px;
  }

  .header-stiletto__mega-col-title {
    display: block;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    transition: color 0.2s ease;
  }

  .header-stiletto__mega-col-title:hover {
    color: #666;
  }

  .header-stiletto__mega-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-stiletto__mega-sublist li a {
    display: block;
    color: #555;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.02em;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .header-stiletto__mega-sublist li a:hover {
    color: #000;
  }

  /* Image area (right side of mega menu) */
  .header-stiletto__mega-image {
    flex-shrink: 0;
    width: 320px;
    position: relative;
    overflow: hidden;
  }

  .header-stiletto__mega-image-wrap {
    position: relative;
    display: block;
    text-decoration: none;
    color: #fff;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .header-stiletto__mega-image-wrap img,
  .header-stiletto__mega-image-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .header-stiletto__mega-image-wrap:hover img {
    transform: scale(1.03);
  }

  .header-stiletto__mega-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, transparent 55%);
  }

  .header-stiletto__mega-image-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    z-index: 1;
  }

  .header-stiletto__mega-image-heading {
    font-size: 18px;
    font-weight: 400;
    margin: 0 0 10px;
    font-family: var(--font-heading-family);
    letter-spacing: 0.02em;
  }

  .header-stiletto__mega-image-btn {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 18px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    color: #fff;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .header-stiletto__mega-image-btn:hover {
    background: #fff;
    color: #000;
  }

  /* ---- Simple Dropdown (for items without deep children) ---- */
  .header-stiletto__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    padding: 16px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
    z-index: 200;
    list-style: none;
    margin: 0;
  }

  .header-stiletto__nav-item.is-open > .header-stiletto__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header-stiletto__dropdown li a {
    display: block;
    color: #444;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.02em;
    padding: 7px 24px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .header-stiletto__dropdown li a:hover {
    color: #000;
    background: rgba(0, 0, 0, 0.03);
  }

  /* ---- Right placeholder (grid balance) ---- */
  .header-stiletto__right {
    justify-self: end;
  }

  /* ---- Mobile hamburger ---- */
  .header-stiletto__mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 4px;
    transition: color 0.3s ease;
  }

  .header-stiletto__mobile-toggle .svg-wrapper {
    display: flex;
    width: 22px;
    height: 22px;
  }

  .header-stiletto__mobile-toggle .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .header-stiletto-wrapper.is-scrolled .header-stiletto__mobile-toggle,
  .header-stiletto-wrapper.is-mega-open .header-stiletto__mobile-toggle {
    color: #1a1a1a;
  }

  /* ---- Mobile drawer ---- */
  .header-stiletto__mobile-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 380px;
    max-width: 90vw;
    height: 100vh;
    height: 100dvh;
    background: #fff;
    z-index: 300;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .header-stiletto__mobile-drawer.is-open {
    transform: translateX(0);
  }

  /* Drawer header: logo + icons + close */
  .header-stiletto__drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    flex-shrink: 0;
  }

  .header-stiletto__drawer-logo {
    display: flex;
    align-items: center;
  }

  .header-stiletto__drawer-logo a {
    text-decoration: none;
    color: #1a1a1a;
    display: flex;
    align-items: center;
  }

  .header-stiletto__drawer-logo img {
    max-height: 28px;
    width: auto;
  }

  .header-stiletto__drawer-logo .h2 {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0;
    font-family: var(--font-heading-family);
    color: #1a1a1a;
  }

  .header-stiletto__drawer-icons {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .header-stiletto__drawer-icons a,
  .header-stiletto__drawer-icons button {
    display: flex;
    align-items: center;
    color: #1a1a1a;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header-stiletto__drawer-icons .svg-wrapper {
    display: flex;
    width: 20px;
    height: 20px;
  }

  .header-stiletto__drawer-icons .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* Drawer body (scrollable) */
  .header-stiletto__drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 0 20px;
  }

  /* Mobile nav */
  .header-stiletto__mobile-nav {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-stiletto__mobile-nav > li {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  /* Nav item with image thumbnail */
  .header-stiletto__mobile-nav-row {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 14px;
    padding: 12px 0;
    text-decoration: none;
    color: #1a1a1a;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
  }

  .header-stiletto__mobile-nav-thumb {
    width: 56px;
    height: 56px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f5f5f5;
  }

  .header-stiletto__mobile-nav-thumb img,
  .header-stiletto__mobile-nav-thumb svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .header-stiletto__mobile-nav-label {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .header-stiletto__mobile-nav-arrow {
    flex-shrink: 0;
    display: flex;
    width: 14px;
    height: 14px;
    color: #999;
  }

  .header-stiletto__mobile-nav-arrow svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
    transform: rotate(-90deg);
  }

  /* Nav item without image (plain text) */
  .header-stiletto__mobile-nav > li > a.header-stiletto__mobile-nav-plain,
  .header-stiletto__mobile-nav > li > button.header-stiletto__mobile-nav-plain {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 16px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  /* Mobile subnav */
  .header-stiletto__mobile-subnav {
    list-style: none;
    margin: 0;
    padding: 0 0 12px 16px;
    display: none;
  }

  .header-stiletto__mobile-subnav.is-open {
    display: block;
  }

  .header-stiletto__mobile-subnav li a {
    display: block;
    color: #555;
    text-decoration: none;
    font-size: 13px;
    padding: 7px 0;
    transition: color 0.2s ease;
  }

  .header-stiletto__mobile-subnav li a:hover {
    color: #000;
  }

  .header-stiletto__mobile-subnav-child {
    padding-left: 14px;
  }

  .header-stiletto__mobile-subnav-child a {
    font-size: 12px !important;
    color: #888 !important;
  }

  /* Drawer footer: utility links + account + social */
  .header-stiletto__drawer-footer {
    padding: 0 20px 24px;
    flex-shrink: 0;
  }

  .header-stiletto__drawer-utility {
    list-style: none;
    margin: 0;
    padding: 16px 0 0;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .header-stiletto__drawer-utility li a {
    display: block;
    color: #555;
    text-decoration: none;
    font-size: 14px;
    padding: 8px 0;
    transition: color 0.2s ease;
  }

  .header-stiletto__drawer-utility li a:hover {
    color: #000;
  }

  .header-stiletto__drawer-account {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 14px;
    padding: 16px 0 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    margin-top: 8px;
  }

  .header-stiletto__drawer-account .svg-wrapper {
    display: flex;
    width: 20px;
    height: 20px;
  }

  .header-stiletto__drawer-account .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .header-stiletto__drawer-social {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0 0;
  }

  .header-stiletto__drawer-social a {
    display: flex;
    color: #1a1a1a;
    transition: color 0.2s ease;
  }

  .header-stiletto__drawer-social a:hover {
    color: #666;
  }

  .header-stiletto__drawer-social .svg-wrapper {
    display: flex;
    width: 22px;
    height: 22px;
  }

  .header-stiletto__drawer-social .svg-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* Mobile overlay */
  .header-stiletto__mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 250;
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .header-stiletto__mobile-overlay.is-open {
    display: block;
    opacity: 1;
  }

  /* ---- Responsive ---- */
  @media screen and (max-width: 989px) {
    .header-stiletto__top-bar {
      display: none;
    }

    .header-stiletto__main {
      grid-template-columns: auto 1fr auto;
      padding: 10px 20px 12px;
    }

    .header-stiletto__nav {
      display: none;
    }

    .header-stiletto__mobile-toggle {
      display: flex;
    }

    .header-stiletto__logo .h2 {
      font-size: 18px;
    }

    .header-stiletto__logo img {
      max-height: 30px;
    }

    .header-stiletto__right-icons {
      gap: 12px;
    }

    .header-stiletto__right-icons .svg-wrapper {
      width: 20px;
      height: 20px;
    }
  }

  /* ---- Hide top bar on sticky scroll ---- */
  .header-stiletto-wrapper.is-scrolled .header-stiletto__top-bar {
    display: none;
  }
</style>

{%- comment -%}
  =============================================
  Header Stiletto - Transparent overlay header
  =============================================
  - Logo left, center mega nav, utility menu top-right
  - Mega menu on hover with optional image/slideshow per menu item
  - Header bg transitions to white when mega menu is open
{%- endcomment -%}

{%- liquid
  comment
    Build a lookup map: mega_image blocks keyed by menu handle
  endcomment
  assign mega_image_blocks = section.blocks | where: 'type', 'mega_image'
-%}

<header-stiletto class="header-stiletto-wrapper" data-sticky="{{ section.settings.enable_sticky }}">
  {%- comment -%} ---- TOP BAR: utility text links only ---- {%- endcomment -%}
  {%- if section.settings.top_menu != blank -%}
    <div class="header-stiletto__top-bar">
      <ul class="header-stiletto__top-menu" role="list">
        {%- for link in section.settings.top_menu.links -%}
          <li>
            <a
              href="{{ link.url }}"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              {{ link.title | escape }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  {%- comment -%} ---- MAIN ROW: Logo | Nav | Icons ---- {%- endcomment -%}
  <div class="header-stiletto__main">
    {%- comment -%} Mobile hamburger {%- endcomment -%}
    <button class="header-stiletto__mobile-toggle" aria-label="Menu" data-drawer-toggle>
      <span class="svg-wrapper">{{ 'icon-hamburger.svg' | inline_asset_content }}</span>
    </button>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="header-stiletto__logo">
      {%- if request.page_type == 'index' -%}<h1 style="margin:0;">{%- endif -%}
      <a href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {% capture sizes %}(max-width: {{ section.settings.logo_width | times: 2 }}px) 50vw, {{ section.settings.logo_width }}px{% endcapture %}
          {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
          {{
            settings.logo
            | image_url: width: 600
            | image_tag:
              class: 'header-stiletto__logo-img',
              widths: widths,
              height: logo_height,
              width: section.settings.logo_width,
              alt: logo_alt,
              sizes: sizes,
              preload: true
          }}
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}</h1>{%- endif -%}
    </div>

    {%- comment -%} ---- CENTER NAV - Mega menu on hover ---- {%- endcomment -%}
    {%- if section.settings.menu != blank -%}
      <nav class="header-stiletto__nav" aria-label="Main navigation">
        <ul class="header-stiletto__nav-list" role="list">
          {%- for link in section.settings.menu.links -%}
            {%- liquid
              comment
                Determine menu type:
                - mega: has grandchildren OR has a matched mega_image block
                - dropdown: has children but no grandchildren and no mega_image
                - link: no children
              endcomment

              assign has_grandchildren = false
              for childlink in link.links
                if childlink.links != blank
                  assign has_grandchildren = true
                  break
                endif
              endfor

              assign matched_block = null
              for block in mega_image_blocks
                if block.settings.menu_handle == link.title
                  assign matched_block = block
                  break
                endif
              endfor

              assign use_mega = false
              if has_grandchildren or matched_block != null
                assign use_mega = true
              endif
            -%}

            {%- if link.links != blank -%}
              {%- if use_mega -%}
                {%- comment -%} ===== MEGA MENU ITEM ===== {%- endcomment -%}
                <li class="header-stiletto__nav-item{% if section.settings.mega_menu_width == 0 %} header-stiletto__nav-item--mega-full{% endif %}" data-menu-item="{{ link.handle }}" {% unless section.settings.mega_menu_width == 0 %}style="--mega-menu-width: {{ section.settings.mega_menu_width }}px;"{% endunless %}>
                  <button
                    class="header-stiletto__nav-summary"
                    aria-expanded="false"
                    aria-controls="MegaMenu-Stiletto-{{ forloop.index }}"
                  >
                    <span
                      {%- if link.child_active %}
                        class="header__active-menu-item"
                      {% endif %}
                    >
                      {{ link.title | escape }}
                    </span>
                    <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                  </button>

                  <div class="header-stiletto__mega-dropdown" id="MegaMenu-Stiletto-{{ forloop.index }}">
                    <div class="header-stiletto__mega-inner">
                      <ul class="header-stiletto__mega-links" role="list">
                        {%- for childlink in link.links -%}
                          <li class="header-stiletto__mega-col">
                            <a href="{{ childlink.url }}" class="header-stiletto__mega-col-title">
                              {{- childlink.title | escape -}}
                            </a>
                            {%- if childlink.links != blank -%}
                              <ul class="header-stiletto__mega-sublist" role="list">
                                {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a
                                      href="{{ grandchildlink.url }}"
                                      {% if grandchildlink.current %}
                                        aria-current="page"
                                      {% endif %}
                                    >
                                      {{ grandchildlink.title | escape }}
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>

                      {%- if matched_block != null -%}
                        <div class="header-stiletto__mega-image" {{ matched_block.shopify_attributes }}>
                          <a
                            href="{{ matched_block.settings.image_link | default: '#' }}"
                            class="header-stiletto__mega-image-wrap"
                          >
                            {%- if matched_block.settings.image != blank -%}
                              {{
                                matched_block.settings.image
                                | image_url: width: 640
                                | image_tag: loading: 'lazy', sizes: '320px', widths: '320, 480, 640'
                              }}
                            {%- else -%}
                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                            <div class="header-stiletto__mega-image-overlay"></div>
                            <div class="header-stiletto__mega-image-content">
                              {%- if matched_block.settings.image_heading != blank -%}
                                <p class="header-stiletto__mega-image-heading">
                                  {{ matched_block.settings.image_heading }}
                                </p>
                              {%- endif -%}
                              {%- if matched_block.settings.image_button_label != blank -%}
                                <span class="header-stiletto__mega-image-btn">
                                  {{- matched_block.settings.image_button_label | escape -}}
                                </span>
                              {%- endif -%}
                            </div>
                          </a>
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </li>

              {%- else -%}
                {%- comment -%} ===== SIMPLE DROPDOWN ===== {%- endcomment -%}
                <li
                  class="header-stiletto__nav-item header-stiletto__nav-item--dropdown"
                  data-menu-item="{{ link.handle }}"
                >
                  <button
                    class="header-stiletto__nav-summary"
                    aria-expanded="false"
                    aria-controls="MegaMenu-Stiletto-{{ forloop.index }}"
                  >
                    <span
                      {%- if link.child_active %}
                        class="header__active-menu-item"
                      {% endif %}
                    >
                      {{ link.title | escape }}
                    </span>
                    <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                  </button>

                  <ul class="header-stiletto__dropdown" id="MegaMenu-Stiletto-{{ forloop.index }}" role="list">
                    {%- for childlink in link.links -%}
                      <li>
                        <a
                          href="{{ childlink.url }}"
                          {% if childlink.current %}
                            aria-current="page"
                          {% endif %}
                        >
                          {{ childlink.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </li>
              {%- endif -%}

            {%- else -%}
              {%- comment -%} ===== Plain link (no children) ===== {%- endcomment -%}
              <li class="header-stiletto__nav-item" data-menu-item="{{ link.handle }}">
                <a
                  href="{{ link.url }}"
                  class="header-stiletto__nav-link"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  <span
                    {%- if link.current %}
                      class="header__active-menu-item"
                    {% endif %}
                  >
                    {{ link.title | escape }}
                  </span>
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- comment -%} Right side icons: search, account, cart {%- endcomment -%}
    <div class="header-stiletto__right-icons">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" aria-label="{{ 'general.search.search' | t }}">
          <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
        </a>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          aria-label="{{ 'customer.log_in' | t }}"
        >
          <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" aria-label="{{ 'templates.cart.cart' | t }}" id="cart-icon-bubble">
        <span class="header-stiletto__icon-wrap">
          {%- if cart == empty -%}
            <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
            <span class="header-stiletto__cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </span>
      </a>
    </div>
  </div>
</header-stiletto>

{%- comment -%} ---- MOBILE DRAWER ---- {%- endcomment -%}

{%- liquid
  assign mobile_image_blocks = section.blocks | where: 'type', 'mobile_menu_image'
-%}

<div class="header-stiletto__mobile-overlay" data-drawer-overlay></div>
<div class="header-stiletto__mobile-drawer" data-drawer>
  {%- comment -%} Drawer header: Logo + Search + Cart + Close {%- endcomment -%}
  <div class="header-stiletto__drawer-header">
    <div class="header-stiletto__drawer-logo">
      <a href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 300 | image_tag: height: 28, alt: shop.name }}
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>
    <div class="header-stiletto__drawer-icons">
      <a href="{{ routes.search_url }}" aria-label="Search">
        <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="Cart">
        <span class="header-stiletto__icon-wrap">
          {%- if cart == empty -%}
            <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
            <span class="header-stiletto__cart-count" style="background:#1a1a1a;color:#fff;">
              {{- cart.item_count -}}
            </span>
          {%- endif -%}
        </span>
      </a>
      <button aria-label="Close" data-drawer-close>
        <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
      </button>
    </div>
  </div>

  {%- comment -%} Drawer body (scrollable) {%- endcomment -%}
  <div class="header-stiletto__drawer-body">
    {%- if section.settings.menu != blank -%}
      <ul class="header-stiletto__mobile-nav" role="list">
        {%- for link in section.settings.menu.links -%}
          <li>
            {%- comment -%} Find matching mobile image block for this nav item {%- endcomment -%}
            {%- assign mobile_matched = null -%}
            {%- for block in mobile_image_blocks -%}
              {%- if block.settings.menu_handle == link.title -%}
                {%- assign mobile_matched = block -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if link.links != blank -%}
              {%- comment -%} Has children: show as expandable row {%- endcomment -%}
              {%- if mobile_matched != null and mobile_matched.settings.image != blank -%}
                {%- comment -%} Row WITH thumbnail image {%- endcomment -%}
                <button
                  class="header-stiletto__mobile-nav-row"
                  data-mobile-toggle="{{ forloop.index }}"
                  {{ mobile_matched.shopify_attributes }}
                >
                  <div class="header-stiletto__mobile-nav-thumb">
                    {{
                      mobile_matched.settings.image
                      | image_url: width: 120
                      | image_tag: loading: 'lazy', sizes: '56px', widths: '56, 112'
                    }}
                  </div>
                  <span class="header-stiletto__mobile-nav-label">{{ link.title | escape }}</span>
                  <span class="header-stiletto__mobile-nav-arrow">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                </button>
              {%- else -%}
                {%- comment -%} Row WITHOUT thumbnail {%- endcomment -%}
                <button class="header-stiletto__mobile-nav-plain" data-mobile-toggle="{{ forloop.index }}">
                  {{ link.title | escape }}
                  <span class="header-stiletto__mobile-nav-arrow">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                </button>
              {%- endif -%}

              <ul class="header-stiletto__mobile-subnav" data-mobile-subnav="{{ forloop.index }}">
                {%- for childlink in link.links -%}
                  <li>
                    <a href="{{ childlink.url }}">{{ childlink.title | escape }}</a>
                  </li>
                  {%- if childlink.links != blank -%}
                    {%- for grandchildlink in childlink.links -%}
                      <li class="header-stiletto__mobile-subnav-child">
                        <a href="{{ grandchildlink.url }}">{{ grandchildlink.title | escape }}</a>
                      </li>
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}
              </ul>

            {%- else -%}
              {%- comment -%} No children: plain link {%- endcomment -%}
              {%- if mobile_matched != null and mobile_matched.settings.image != blank -%}
                <a
                  href="{{ link.url }}"
                  class="header-stiletto__mobile-nav-row"
                  {{ mobile_matched.shopify_attributes }}
                >
                  <div class="header-stiletto__mobile-nav-thumb">
                    {{
                      mobile_matched.settings.image
                      | image_url: width: 120
                      | image_tag: loading: 'lazy', sizes: '56px', widths: '56, 112'
                    }}
                  </div>
                  <span class="header-stiletto__mobile-nav-label">{{ link.title | escape }}</span>
                </a>
              {%- else -%}
                <a href="{{ link.url }}" class="header-stiletto__mobile-nav-plain">{{ link.title | escape }}</a>
              {%- endif -%}
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {%- comment -%} Drawer footer: utility links, account, social {%- endcomment -%}
  <div class="header-stiletto__drawer-footer">
    {%- if section.settings.top_menu != blank -%}
      <ul class="header-stiletto__drawer-utility" role="list">
        {%- for link in section.settings.top_menu.links -%}
          <li>
            <a href="{{ link.url }}">{{ link.title | escape }}</a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if shop.customer_accounts_enabled -%}
      <a
        href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
        class="header-stiletto__drawer-account"
      >
        <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
        <span>
          {%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}Register / Login{%- endif -%}
        </span>
      </a>
    {%- endif -%}

    {%- if section.settings.show_social_mobile -%}
      <div class="header-stiletto__drawer-social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener">
            <span class="svg-wrapper">{{ 'icon-facebook.svg' | inline_asset_content }}</span>
