{%- style -%}
  #Testimonials-{{ section.id }} {
    --testi-bg: {{ section.settings.bg_color }};
    --testi-text: {{ section.settings.text_color }};
    --testi-heading-color: {{ section.settings.heading_color }};
    --testi-card-bg: {{ section.settings.card_bg_color }};
    --testi-card-border: {{ section.settings.card_border_color }};
    --testi-accent: {{ section.settings.accent_color }};
    --testi-card-radius: {{ section.settings.card_border_radius }}px;
    --testi-pt: {{ section.settings.padding_top }}px;
    --testi-pb: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #Testimonials-{{ section.id }} {
      --testi-pt: {{ section.settings.padding_top | times: 0.7 | round }}px;
      --testi-pb: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div id="Testimonials-{{ section.id }}" class="testimonials">
  <div class="testimonials__padding">
    <div class="testimonials__inner page-width">

      {%- comment -%} Header {%- endcomment -%}
      <div class="testimonials__header">
        {%- if section.settings.subheading != blank -%}
          <span class="testimonials__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- comment -%} Cards Grid {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="testimonials__grid">
          {%- for block in section.blocks -%}
            <div class="testimonials__card" {{ block.shopify_attributes }}>

              {%- comment -%} Card Top: Logo + Company {%- endcomment -%}
              <div class="testimonials__card-top">
                {%- if block.settings.logo != blank -%}
                  <div class="testimonials__card-logo">
                    {{
                      block.settings.logo
                      | image_url: width: 300
                      | image_tag:
                          loading: 'lazy',
                          widths: '80, 150, 300',
                          sizes: '12rem',
                          alt: block.settings.logo.alt | default: block.settings.company_name
                    }}
                  </div>
                {%- endif -%}
                {%- if block.settings.company_name != blank -%}
                  <span class="testimonials__card-company">{{ block.settings.company_name }}</span>
                {%- endif -%}
              </div>

              {%- comment -%} Quote Title {%- endcomment -%}
              {%- if block.settings.quote_title != blank -%}
                <h3 class="testimonials__card-title">{{ block.settings.quote_title }}</h3>
              {%- endif -%}

              {%- comment -%} Quote Text {%- endcomment -%}
              {%- if block.settings.quote_text != blank -%}
                <p class="testimonials__card-text">{{ block.settings.quote_text }}</p>
              {%- endif -%}

              {%- comment -%} Card Bottom: Stars + Years {%- endcomment -%}
              <div class="testimonials__card-bottom">
                <div class="testimonials__card-rating">
                  <div class="testimonials__stars">
                    {%- for i in (1..5) -%}
                      {%- if i <= block.settings.rating -%}
                        <svg class="testimonials__star testimonials__star--filled" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- else -%}
                        <svg class="testimonials__star" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.rating_label != blank -%}
                    <span class="testimonials__rating-label">{{ block.settings.rating_label }}</span>
                  {%- endif -%}
                </div>

                {%- if block.settings.years_partnered != blank -%}
                  <div class="testimonials__card-years">
                    <span class="testimonials__years-icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </span>
                    <div class="testimonials__years-text">
                      <strong>{{ block.settings.years_partnered }}</strong>
                      <span>YEARS PARTNERED</span>
                    </div>
                  </div>
                {%- endif -%}
              </div>

            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  /* ============================================
     CLIENT TESTIMONIALS
     ============================================ */

  .testimonials {
    background-color: var(--testi-bg, #0a0a0a);
    color: var(--testi-text, #ffffff);
  }

  .testimonials__padding {
    padding-top: var(--testi-pt, 80px);
    padding-bottom: var(--testi-pb, 48px);
  }

  .testimonials__inner {
    display: flex;
    flex-direction: column;
    gap: 3.2rem;
  }

  /* --- Header --- */
  .testimonials__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .testimonials__subheading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.45;
  }

  .testimonials__heading {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.6rem;
    color: var(--testi-heading-color, #ffffff);
    letter-spacing: -0.02em;
  }

  /* --- Grid / Slider --- */
  .testimonials__grid {
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.4rem;
  }

  .testimonials__grid::-webkit-scrollbar {
    display: none;
  }

  /* --- Card --- */
  .testimonials__card {
    background-color: var(--testi-card-bg, #141414);
    border: 1px solid var(--testi-card-border, #222222);
    border-radius: var(--testi-card-radius, 12px);
    padding: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    flex: 0 0 85%;
    max-width: 85%;
    scroll-snap-align: start;
  }

  /* Card Top: Logo + Company */
  .testimonials__card-top {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .testimonials__card-logo {
    height: 2.2rem;
    display: flex;
    align-items: center;
  }

  .testimonials__card-logo img {
    height: 100%;
    width: auto;
    max-width: 14rem;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .testimonials__card-company {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  /* Quote Title */
  .testimonials__card-title {
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    color: var(--testi-heading-color, #ffffff);
  }

  /* Quote Text */
  .testimonials__card-text {
    font-size: 1.3rem;
    line-height: 1.65;
    margin: 0;
    opacity: 0.55;
  }

  /* Card Bottom: Stars + Years */
  .testimonials__card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.6rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .testimonials__card-rating {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .testimonials__stars {
    display: flex;
    gap: 0.2rem;
  }

  .testimonials__star {
    color: rgba(255, 255, 255, 0.2);
  }

  .testimonials__star--filled {
    color: var(--testi-accent, #ff4500);
  }

  .testimonials__rating-label {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  /* Years Partnered */
  .testimonials__card-years {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-align: right;
  }

  .testimonials__years-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    background-color: var(--testi-accent, #ff4500);
    color: #ffffff;
    flex-shrink: 0;
  }

  .testimonials__years-icon svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  .testimonials__years-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .testimonials__years-text strong {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1;
    color: var(--testi-heading-color, #ffffff);
  }

  .testimonials__years-text span {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  /* ============================================
     RESPONSIVE - TABLET+ (750px)
     ============================================ */
  @media screen and (min-width: 750px) {
    .testimonials__heading {
      font-size: 3.6rem;
    }

    .testimonials__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      overflow: visible;
    }

    .testimonials__card {
      flex: none;
      max-width: none;
      padding: 3rem;
    }

    .testimonials__card-title {
      font-size: 2rem;
    }

    .testimonials__card-text {
      font-size: 1.35rem;
    }
  }

  /* ============================================
     RESPONSIVE - DESKTOP (990px)
     ============================================ */
  @media screen and (min-width: 990px) {
    .testimonials__heading {
      font-size: 4.8rem;
    }

    .testimonials__card {
      padding: 3.2rem;
      gap: 1.6rem;
    }

    .testimonials__card-title {
      font-size: 3rem;
      font-weight:500;
    }

    .testimonials__card-text {
      font-size: 2rem;
      font-weight:300;
    }
    .testimonials__stars svg{
      width:32px;
      height:32px;
    }
  }
</style>

