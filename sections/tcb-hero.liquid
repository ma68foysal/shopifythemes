{%- style -%}
    /* ========== TCB SLIDESHOW ========== */
    .tcb-slideshow {
      --tcb-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      --tcb-heading-color: {{ section.settings.heading_color }};
      --tcb-text-color: {{ section.settings.text_color }};
      --tcb-heading-size: {{ section.settings.heading_size }}px;
      --tcb-subheading-size: {{ section.settings.subheading_size }}px;
      --tcb-btn-bg: {{ section.settings.button_bg }};
      --tcb-btn-text: {{ section.settings.button_text_color }};
      --tcb-btn-hover-bg: {{ section.settings.button_hover_bg }};
      --tcb-btn-size: {{ section.settings.button_font_size }}px;
      width: 100%;
      height: {{ section.settings.slide_height }};
      min-height: 550px;
      overflow: hidden;
      background: #0a0503;
      position: relative;
    }

    /*
     * All sections AFTER the slideshow in header-group, plus main,
     * must sit above the GSAP-pinned slideshow (which becomes position:fixed).
     */
    .shopify-section-group-header-group .shopify-section:not(.tcb-slideshow-section) {
      position: relative;
      z-index: 10;
    }
    #MainContent {
      position: relative;
      z-index: 10;
    }

    /* Slides */
    .tcb-slideshow__slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1s ease;
      z-index: 1;
    }
    .tcb-slideshow__slide.is-active {
      opacity: 1;
      z-index: 2;
    }
    .tcb-slideshow__slide-media {
      position: absolute;
      inset: 0;
    }
    .tcb-slideshow__slide-media img,
    .tcb-slideshow__slide-media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .tcb-slideshow__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(0,0,0, var(--tcb-overlay-opacity)) 0%,
        rgba(0,0,0, calc(var(--tcb-overlay-opacity) * 0.08)) 50%,
        rgba(0,0,0, calc(var(--tcb-overlay-opacity) * 0.03)) 100%
      );
      z-index: 2;
    }

    /* Content at bottom center */
    .tcb-slideshow__content {
      position: absolute;
      bottom: 60px;
      left: 0;
      right: 0;
      z-index: 3;
      text-align: center;
      padding: 0 24px;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
  }
    .tcb-slideshow__heading {
      font-family: var(--font-body-family);
      font-size: clamp(24px, 4.73vw, var(--tcb-heading-size));
      color: var(--tcb-heading-color);
      font-weight: var(--font-heading-weight);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 20px;
      line-height: 1.1;
    }
    .tcb-slideshow__subheading {
      font-size: clamp(12px, 1.1vw, var(--tcb-subheading-size));
      color: var(--tcb-text-color);
      margin: 0 auto 28px;
      max-width: 520px;
      line-height: 1.6;
      opacity: 0.85;
    }
    .tcb-slideshow__btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 36px;
      background: var(--tcb-btn-bg);
      color: var(--tcb-btn-text);
      text-decoration: none;
      text-transform: uppercase;
      font-size: var(--tcb-btn-size);
      font-weight: 700;
      letter-spacing: 0.1em;
      transition: background 0.3s;
      font-family: var(--font-body-family);
      border-radius:100px;
    }
    .tcb-slideshow__btn:hover {
      background: var(--tcb-btn-hover-bg);
      color:var(--tcb-heading-color);
    }

    /* Arrows */
    .tcb-slideshow__controls {
      position: absolute;
      bottom: 24px;
      right: 28px;
      z-index: 5;
      display: flex;
      gap: 8px;
    }
    .tcb-slideshow__arrow {
      width: 36px;
      height: 36px;
      border: 1px solid rgba(255,255,255,0.35);
      border-radius: 50%;
      background: transparent;
      color: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.3s;
    }
    .tcb-slideshow__arrow:hover {
      border-color: #fff;
    }
    .tcb-slideshow__arrow svg {
      width: 14px;
      height: 14px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 749px) {
      .tcb-slideshow {
        min-height: 400px;
      }
      .tcb-slideshow__content {
        top: 50%;
        padding: 0 16px;
        flex-direction:column;
        justify-content:center;
        gap:12px;
      }
      .tcb-slideshow__heading {
        font-size: clamp(22px, 7vw, 32px);
        margin-bottom: 12px;
      }
      .tcb-slideshow__subheading {
        font-size: 13px;
        margin-bottom: 20px;
      }
      .tcb-slideshow__btn {
        padding: 11px 28px;
        font-size: 11px;
      }
      .tcb-slideshow__controls {
        bottom: 16px;
        right: 16px;
        gap: 6px;
      }
      .tcb-slideshow__arrow {
        width: 32px;
        height: 32px;
      }
      .tcb-slideshow__arrow svg {
        width: 12px;
        height: 12px;
      }
    }
{%- endstyle -%}

{%- if template.suffix == 'inova' -%}
  <div class="tcb-slideshow" id="TcbSlideshow-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="tcb-slideshow__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
        <div class="tcb-slideshow__slide-media">
          {%- if block.settings.video != blank -%}
            {{
              block.settings.video
              | video_tag: image_size: '3840x', autoplay: true, loop: true, muted: true, controls: false
            }}
          {%- elsif block.settings.video_url != blank -%}
            {%- liquid
              assign vid_url = block.settings.video_url
              assign vid_id = vid_url | split: '/' | last | split: '=' | last | split: '&' | first | split: '?' | first
              assign is_youtube = false
              if vid_url contains 'youtube' or vid_url contains 'youtu.be'
                assign is_youtube = true
              endif
            -%}
            {%- if is_youtube -%}
              <iframe
                src="https://www.youtube.com/embed/{{ vid_id }}?autoplay=1&mute=1&loop=1&playlist={{ vid_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
                allow="autoplay; encrypted-media"
                allowfullscreen
                frameborder="0"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
                title="{{ block.settings.heading | escape }}"
              ></iframe>
            {%- else -%}
              <iframe
                src="https://player.vimeo.com/video/{{ vid_id }}?autoplay=1&muted=1&loop=1&controls=0&background=1"
                allow="autoplay; encrypted-media"
                allowfullscreen
                frameborder="0"
                style="position:absolute;inset:0;width:100%;height:100%;border:0;"
                title="{{ block.settings.heading | escape }}"
              ></iframe>
            {%- endif -%}
          {%- elsif block.settings.image != blank -%}
            {%- assign h = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round -%}
            {{
              block.settings.image
              | image_url: width: 3840
              | image_tag: sizes: '100vw', widths: '375,750,1100,1500,2000,3840', height: h, loading: 'eager'
            }}
          {%- else -%}
            <div style="width:100%;height:100%;background:#1a0a05;">&nbsp;</div>
          {%- endif -%}
        </div>
        <div class="tcb-slideshow__overlay">&nbsp;</div>
        <div class="tcb-slideshow__content">
          {%- if block.settings.heading != blank -%}
            <h2 class="tcb-slideshow__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="tcb-slideshow__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link | default: '#' }}" class="tcb-slideshow__btn">
              {{ block.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if section.blocks.size > 1 -%}
      <div class="tcb-slideshow__controls">
        <button class="tcb-slideshow__arrow tcb-slideshow__arrow--prev" aria-label="Previous slide">
          <svg viewBox="0 0 24 24">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="tcb-slideshow__arrow tcb-slideshow__arrow--next" aria-label="Next slide">
          <svg viewBox="0 0 24 24">
            <polyline points="9 6 15 12 9 18"></polyline>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </div>

  <!-- Lenis + GSAP CDNs -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lenis@1.3.21/dist/lenis.min.css">
  <script src="https://cdn.jsdelivr.net/npm/lenis@1.3.21/dist/lenis.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/ScrollTrigger.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      /* ===== LENIS SMOOTH SCROLL ===== */
      var lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
      function raf(t) {
        lenis.raf(t);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      /* ===== GSAP PIN ===== */
      gsap.registerPlugin(ScrollTrigger);

      var slideshow = document.getElementById('TcbSlideshow-{{ section.id }}');
      if (!slideshow) return;

      var sectionWrapper = slideshow.closest('.shopify-section');
      var nextSection = sectionWrapper ? sectionWrapper.nextElementSibling : null;

      ScrollTrigger.create({
        trigger: slideshow,
        start: 'top top',
        endTrigger: nextSection || slideshow,
        end: nextSection ? 'top top' : 'bottom top',
        pin: true,
        pinSpacing: false,
      });

      /* ===== SLIDESHOW AUTO-ROTATE ===== */
      var slides = slideshow.querySelectorAll('.tcb-slideshow__slide');
      var cur = 0;
      var autoRotate = '{{ section.settings.auto_rotate }}' === 'true';
      var speed = parseInt('{{ section.settings.slide_speed }}', 10) * 1000 || 5000;

      function go(i) {
        slides.forEach(function (s) {
          s.classList.remove('is-active');
        });
        cur = ((i % slides.length) + slides.length) % slides.length;
        slides[cur].classList.add('is-active');
      }

      var prev = slideshow.querySelector('.tcb-slideshow__arrow--prev');
      var next = slideshow.querySelector('.tcb-slideshow__arrow--next');
      if (prev)
        prev.addEventListener('click', function () {
          go(cur - 1);
        });
      if (next)
        next.addEventListener('click', function () {
          go(cur + 1);
        });
      if (autoRotate && slides.length > 1)
        setInterval(function () {
          go(cur + 1);
        }, speed);
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "TCB Slideshow",
  "tag": "section",
  "class": "tcb-slideshow-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "select",
      "id": "slide_height",
      "label": "Slide height",
      "options": [
        { "value": "60vh", "label": "Small" },
        { "value": "75vh", "label": "Medium" },
        { "value": "85vh", "label": "Large" },
        { "value": "100vh", "label": "Full screen" }
      ],
      "default": "100vh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "slide_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Slide speed",
      "default": 5
    },
    {
      "type": "header",
      "content": "Content colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subheading color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content font sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading max size",
      "default": 54
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Subheading max size",
      "default": 15
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#c8902e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#6b3a2a"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Button font size",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify hosted video",
          "info": "Overrides image if set. Autoplays muted."
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (YouTube / Vimeo)",
          "info": "Overrides image if set. Paste a YouTube or Vimeo URL."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "DATE SWEETENED CHOCOLATE"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TCB Slideshow",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "DATE SWEETENED CHOCOLATE",
            "button_label": "SHOP NOW"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "INDULGE FREELY",
            "button_label": "SHOP NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
